---

---

<div class="bev-premios">
  <div class="container-fluid px-4 px-lg-5">
    <div class="bev-promo-wrapper text-center mx-auto">
      <p class="bev-promo-text">
        "Tu talento merece ser descubierto. Participa en el Primer Premio
        Nacional de Novela."
      </p>

      <div class="bev-promo-img-wrapper">
        <img
          src="/assets/img/carrusels/premionacional.webp"
          alt="Premio Nacional de Novela"
          class="bev-promo-img"
          loading="lazy"
        />

        <div
          class="bev-btn-premio-wrap"
          style="position:absolute; bottom:5%; left:20%; transform:translateX(-50%);"
        >
          <a
            class="btn bev-btn-premio"
            href="/assets/img/doc/bases.pdf"
            target="_blank"
            rel="noopener noreferrer"
          >
            Participa
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .bev-premios {
    background-color: var(--pr-gray-1000);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 5rem 0 3rem;
  }

  .bev-promo-wrapper {
    max-width: 1400px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
  }

  .bev-promo-text {
    font-family: "Lato", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--pr-gray-900);
    background-color: var(--pr-gray-1400);
    padding: 2.5rem 2rem;
    margin: 0;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
  }

  .bev-promo-img-wrapper {
    position: relative;
    line-height: 0;
  }

  .bev-promo-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .bev-btn-premio {
    background-color: var(--pr-gray-1400);
    color: var(--pr-white);
    border: 2px solid rgba(255, 255, 255, 0.7);
    padding: 0.9rem 2.5rem;
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 4px;
    backdrop-filter: blur(6px);
    white-space: nowrap;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease;
  }

  .bev-btn-premio:hover {
    background-color: rgba(0, 0, 0, 0.9);
    border-color: var(--pr-white);
    color: var(--pr-white);
    transform: scale(1.05);
  }

  @media (max-width: 576px) {
    .bev-premios {
      padding: 3rem 0 2rem;
    }

    .bev-promo-wrapper {
      max-width: 100%;
    }

    .bev-promo-text {
      padding: 1.5rem 1rem;
    }

    .bev-btn-premio {
      padding: 0.65rem 1.5rem;
      font-size: 0.85rem;
    }
  }
</style>
