---
import Topbar from "../components/topbar.astro";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
import { ClientRouter } from 'astro:transitions';
// 1. Mover el CSS de AOS aquí arriba evita parpadeos visuales
import "aos/dist/aos.css";

const { title = "Bajo el Volcán Editorial Literaria" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <ClientRouter />

    <link rel="stylesheet" href="/styles/css/body.css" />
    <link rel="stylesheet" href="/styles/css/var.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <Topbar />
    <Navbar />
    
    <main>
      <slot />
    </main>

    <Footer />

    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
    
    <div id="bevToast" class="bev-toast-container"></div>

    <script>
      import AOS from "aos";

      function initAOS() {
        AOS.init({
          duration: 900,
          once: false,
          offset: 100,
        });
      }

      // Inicializa al cargar por primera vez
      initAOS();

      // RE-INICIALIZA cuando cambias de página (necesario por el ClientRouter)
      document.addEventListener("astro:after-swap", initAOS);
    </script>
  </body>
</html>

<style>
  .bev-modal-content {
    border-radius: 0;
    border: none;
    background: var(--bev-cream);
  }
  .bev-modal-header {
    background: var(--bev-ink);
    border: none;
    padding: 0.75rem 1rem;
  }
  .bev-modal-cover {
    min-height: 350px;
    overflow: hidden;
  }

  .bev-modal-titulo {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--bev-ink);
    margin-bottom: 0.25rem;
  }

  .bev-modal-autor {
    font-size: 1rem;
    font-style: italic;
    color: var(--bev-ash);
    margin-bottom: 1rem;
  }

  .bev-modal-desc {
    font-size: 0.95rem;
    color: var(--bev-charcoal);
    line-height: 1.75;
    flex-grow: 1;
  }

  .bev-modal-precio {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--bev-ink);
  }
</style>
