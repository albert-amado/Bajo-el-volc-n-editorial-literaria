---
import Layout from "../../layouts/layout.astro";
import autores from "../../data/autores.json";
import libros from "../../data/libros.json";

export async function getStaticPaths() {
  return autores.map((autor) => ({
    params: { id: autor.id.toString() },
    props: { autor },
  }));
}

const { autor } = Astro.props;

const librosDelAutor = libros.filter((l) => l.autor === autor.nombre);

const getInitials = (nombre: string) => {
  return nombre
    .split(" ")
    .map((n) => n[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();
};
---

<Layout title={`${autor.nombre} - Bajo el Volcán`}>
  <main class="bev-author-profile mt-5 pt-5">
    <div class="container">

      <div class="mb-4">
        <a href="/" class="btn btn-link text-white p-0 text-decoration-none bev-back-link">
          <i class="bi bi-arrow-left"></i> Volver al inicio
        </a>
      </div>

      <div class="row align-items-center mb-5">
        <div class="col-lg-4 text-center mb-4 mb-lg-0">
          <div class="bev-author-detail-avatar mx-auto">
            <img
              src={`/${autor.foto}`}
              alt={autor.nombre}
              class="img-fluid rounded-circle shadow-lg"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="bev-avatar-fallback-large" style="display:none">
              {getInitials(autor.nombre)}
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <span class="bev-section-tag">{autor.nacionalidad}</span>
          <h1 class="display-4 fw-bold text-white mb-3">{autor.nombre}</h1>
          <div class="bev-divider mb-4"></div>
          <p class="lead text-light opacity-75">{autor.bio}</p>
        </div>
      </div>

      <hr class="border-secondary my-5" />

      <div class="row">
        <div class="col-12 mb-4">
          <h3 class="text-white fw-bold">Obras publicadas</h3>
          <p class="text-muted small">
            Explora los títulos de {autor.nombre} en nuestra editorial.
          </p>
        </div>

        {
          librosDelAutor.map((libro) => (
            <div class="col-6 col-md-4 col-lg-3 mb-4">
              <div class="card h-100 bev-book-card-v2 bg-transparent border-0">
                <div class="bev-book-cover-v2">
                  <img
                    src={libro.imagen.startsWith('/') ? libro.imagen : `/${libro.imagen}`}
                    alt={libro.titulo}
                    class="card-img-top rounded shadow"
                  />
                </div>
                <div class="card-body px-0">
                  <h6 class="text-white mb-1">{libro.titulo}</h6>
                  <p class="text-primary fw-bold mb-0">
                    ${libro.precio.toLocaleString("es-CO")}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

    </div>
  </main>
</Layout>

<style>
  .bev-author-profile {
    background-color: var(--pr-gray-900);
    min-height: 100vh;
    color: var(--pr-white);
  }

  .bev-author-detail-avatar {
    width: 280px;
    height: 280px;
    position: relative;
  }

  .bev-author-detail-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 4px solid var(--pr-gray-700);
    border-radius: 50%;
  }

  .bev-avatar-fallback-large {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--pr-gray-900), #444);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: bold;
    color: var(--pr-white);
  }

  .bev-divider {
    height: 4px;
    width: 60px;
    background-color: var(--pr-gray-400);
    border-radius: 2px;
  }

  .bev-section-tag {
    background-color: rgba(255,255,255,0.1);
    color: var(--pr-gray-400);
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  .bev-book-cover-v2 {
    transition: transform 0.3s ease;
  }

  .bev-book-card-v2:hover .bev-book-cover-v2 {
    transform: translateY(-8px);
  }

  .bev-back-link {
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .bev-back-link:hover {
    color: var(--pr-gray-400) !important;
    transform: translateX(-5px);
  }
</style>