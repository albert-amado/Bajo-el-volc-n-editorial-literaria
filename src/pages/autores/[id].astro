---
import Layout from "../../layouts/layout.astro";
import autores from "../../data/autores.json";
import libros from "../../data/libros.json";

export async function getStaticPaths() {
  return autores.map((autor) => ({
    params: { id: autor.id.toString() },
    props: { autor },
  }));
}

const { autor } = Astro.props;

const librosDelAutor = libros.filter((l) => l.autor === autor.nombre);

const getInitials = (nombre: string) => {
  return nombre
    .split(" ")
    .map((n) => n[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();
};
---

<Layout
  title={autor.nombre}
  description={`${autor.bio?.substring(0, 150)}...`}
  image={autor.foto?.startsWith("/") ? autor.foto : `/${autor.foto}`}
  type="profile"
>
  <main class="bev-author-profile mt-5 pt-5">
    <div class="container">
      <div class="mb-4">
        <a href="/" class="bev-back-link">
          <i class="bi bi-arrow-left"></i> Volver al inicio
        </a>
      </div>

      <div class="row align-items-center mb-5">
        <div class="col-lg-4 text-center mb-4 mb-lg-0">
          <div class="bev-author-detail-avatar mx-auto">
            <img
              src={autor.foto.startsWith("/") ? autor.foto : `/${autor.foto}`}
              alt={autor.nombre}
              class="img-fluid shadow-lg"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="bev-avatar-fallback-large" style="display:none">
              {getInitials(autor.nombre)}
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <span class="bev-section-tag">{autor.nacionalidad}</span>
          <h1 class="display-4 fw-bold mb-3">{autor.nombre}</h1>
          <div class="bev-divider mb-4"></div>
          <p class="bev-author-bio">{autor.bio}</p>
        </div>
      </div>

      <hr class="my-5" />

      <div class="row">
        <div class="col-12 mb-4">
          <h3 class="fw-bold">Obras publicadas</h3>
          <p class="bev-author-subtext">
            Explora los títulos de {autor.nombre} en nuestra editorial.
          </p>
        </div>

        {
          librosDelAutor.map((libro) => (
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
              <a
                href={`/libros/${libro.id}`}
                class="card h-100 bev-book-card-v2 text-decoration-none d-block"
              >
                <div class="bev-book-cover-v2">
                  <img
                    src={
                      libro.imagen.startsWith("/")
                        ? libro.imagen
                        : `/${libro.imagen}`
                    }
                    alt={libro.titulo}
                    class="card-img-top rounded shadow"
                  />
                </div>
                <div class="card-body px-0">
                  <h6 class="mb-1">{libro.titulo}</h6>
                  <p class="bev-book-price">
                    ${libro.precio.toLocaleString("es-CO")}
                  </p>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .bev-author-profile {
    background-color: transparent;
    min-height: 100vh;
    color: var(--pr-gray-900);
  }

  /* Link */
  .bev-back-link {
    color: var(--pr-gray-900);
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .bev-back-link:hover {
    transform: translateX(-5px);
    opacity: 0.7;
  }

  /* Avatar */
  .bev-author-detail-avatar {
    width: min(100%, 280px);
    height: min(100vw, 280px);
    max-height: 280px;
  }

  .bev-author-detail-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .bev-avatar-fallback-large {
    width: 100%;
    height: 100%;
    background: var(--pr-gray-400);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: bold;
    color: var(--pr-gray-900);
  }

  /* Tipografía */
  h1,
  h3,
  h6 {
    color: var(--pr-gray-900);
  }

  .bev-author-bio {
    color: var(--pr-gray-900);
    line-height: 1.6;
  }

  .bev-author-subtext {
    color: var(--pr-gray-900);
    font-size: 0.9rem;
  }

  /* Precio */
  .bev-book-price {
    color: var(--pr-gray-900);
    font-weight: 700;
    margin: 0;
  }

  /* Divider */
  .bev-divider {
    height: 4px;
    width: 60px;
    background-color: var(--pr-gray-900);
    border-radius: 2px;
  }

  /* Tag (negro sólido) */
  .bev-section-tag {
    background-color: var(--pr-gray-900);
    color: var(--pr-gray-1000);
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  /* Línea */
  hr {
    border-color: var(--pr-gray-900);
  }

  @media (max-width: 575px) {
    .bev-author-detail-avatar {
      width: min(100%, 220px);
      height: min(72vw, 220px);
    }

    .bev-section-tag {
      display: inline-flex;
      width: auto;
    }

    .bev-divider {
      width: 48px;
    }

    .bev-author-bio,
    .bev-author-subtext {
      font-size: 0.92rem;
    }
  }
</style>
