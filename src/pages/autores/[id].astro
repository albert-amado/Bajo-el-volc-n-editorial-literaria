---
import Layout from "../../layouts/layout.astro";
import autores from "../../data/autores.json";
import libros from "../../data/libros.json";

export async function getStaticPaths() {
  return autores.map((autor) => ({
    params: { id: autor.id.toString() },
    props: { autor },
  }));
}

const { autor } = Astro.props;

const librosDelAutor = libros.filter((l) => l.autor === autor.nombre);

const getInitials = (nombre: string) => {
  return nombre
    .split(" ")
    .map((n) => n[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();
};
---

<Layout title={`${autor.nombre} - Bajo el Volcán`}>
  <main class="bev-author-profile mt-5 pt-5">
    <div class="container">

      <div class="mb-4">
        <a href="/" class="bev-back-link">
          <i class="bi bi-arrow-left"></i> Volver al inicio
        </a>
      </div>

      <div class="row align-items-center mb-5">
        <div class="col-lg-4 text-center mb-4 mb-lg-0">
          <div class="bev-author-detail-avatar mx-auto">
            <img
              src={`/${autor.foto}`}
              alt={autor.nombre}
              class="img-fluid shadow-lg"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="bev-avatar-fallback-large" style="display:none">
              {getInitials(autor.nombre)}
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <span class="bev-section-tag">{autor.nacionalidad}</span>
          <h1 class="display-4 fw-bold mb-3">{autor.nombre}</h1>
          <div class="bev-divider mb-4"></div>
          <p class="bev-author-bio">{autor.bio}</p>
        </div>
      </div>

      <hr class="my-5" />

      <div class="row">
        <div class="col-12 mb-4">
          <h3 class="fw-bold">Obras publicadas</h3>
          <p class="bev-author-subtext">
            Explora los títulos de {autor.nombre} en nuestra editorial.
          </p>
        </div>

        {
          librosDelAutor.map((libro) => (
            <div class="col-6 col-md-4 col-lg-3 mb-4">
              <div
                class="card h-100 bev-book-card-v2 js-autor-modal"
                data-id={libro.id}
                style="cursor:pointer;"
              >
                <div class="bev-book-cover-v2">
                  <img
                    src={libro.imagen.startsWith('/') ? libro.imagen : `/${libro.imagen}`}
                    alt={libro.titulo}
                    class="card-img-top rounded shadow"
                  />
                </div>
                <div class="card-body px-0">
                  <h6 class="mb-1">{libro.titulo}</h6>
                  <p class="bev-book-price">
                    ${libro.precio.toLocaleString("es-CO")}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

    </div>
  </main>

  <!-- MODAL INFO LIBRO -->
  <div class="modal fade" id="modalAutorLibro" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
      <div class="modal-content bev-modal-content">
        <div class="bev-modal-header d-flex justify-content-end">
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body p-0">
          <div class="row g-0" style="min-height: 520px;">

            <!-- Portada -->
            <div class="col-12 col-md-4 bev-modal-cover">
              <img
                id="autorModalPortada"
                src=""
                alt=""
                style="width:100%; height:100%; object-fit:cover; display:block;"
              />
            </div>

            <!-- Info -->
            <div class="col-12 col-md-8 d-flex flex-column p-4 p-lg-5" style="background: var(--bev-cream);">

              <div class="d-flex align-items-center gap-2 mb-2">
                <span id="autorModalEtiqueta" class="bev-etiqueta" style="position:static; font-size:0.7rem; padding:3px 10px;"></span>
                <span id="autorModalGenero" class="bev-eyebrow mb-0" style="font-size:0.72rem;"></span>
              </div>

              <h2 id="autorModalTitulo" class="bev-modal-titulo"></h2>
              <p id="autorModalAutor" class="bev-modal-autor"></p>
              <p id="autorModalDesc" class="bev-modal-desc flex-grow-1 mb-4"></p>

              <!-- Ficha técnica -->
              <div class="d-flex gap-4 mb-4 flex-wrap">
                <div>
                  <p class="bev-ficha-label">ISBN</p>
                  <p id="autorModalISBN" class="bev-ficha-valor"></p>
                </div>
                <div>
                  <p class="bev-ficha-label">Páginas</p>
                  <p id="autorModalPaginas" class="bev-ficha-valor"></p>
                </div>
              </div>

              <!-- Precio y carrito -->
              <div
                class="d-flex align-items-center justify-content-between flex-wrap gap-3 mt-auto pt-3"
                style="border-top: 1px solid var(--bev-cream-dk);"
              >
                <span id="autorModalPrecio" class="bev-modal-precio"></span>
                <button id="autorModalBtnCarrito" class="btn bev-btn-gold">
                  <i class="bi bi-bag-plus me-2"></i>Agregar al carrito
                </button>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import librosData from "../../data/libros.json";
  import { agregarAlCarrito } from "../../js/carrito.js";
  import { setLibros, setAutores } from "../../js/store.js";
  import autoresData from "../../data/autores.json";

  document.addEventListener("DOMContentLoaded", () => {
    setLibros(librosData);
    setAutores(autoresData);

    const etiquetasMap: Record<string, string> = {
      nuevo: "Nuevo",
      destacado: "Destacado",
      preventa: "En preventa",
      descuento: "Oferta",
    };

    const cards = document.querySelectorAll(".js-autor-modal");

    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const id = parseInt(card.getAttribute("data-id") || "0");
        const libro = librosData.find((l) => l.id === id);
        if (!libro) return;

        // Portada
        (document.getElementById("autorModalPortada") as HTMLImageElement).src =
          libro.imagen.startsWith("/") ? libro.imagen : `/${libro.imagen}`;
        (document.getElementById("autorModalPortada") as HTMLImageElement).alt =
          libro.titulo;

        // Etiqueta
        const etiquetaEl = document.getElementById("autorModalEtiqueta")!;
        if (libro.etiqueta) {
          etiquetaEl.textContent = etiquetasMap[libro.etiqueta.toLowerCase()] || libro.etiqueta;
          etiquetaEl.className = `bev-etiqueta bev-etiqueta-${libro.etiqueta.toLowerCase()}`;
          etiquetaEl.classList.remove("d-none");
        } else {
          etiquetaEl.classList.add("d-none");
        }

        // Campos básicos
        document.getElementById("autorModalGenero")!.textContent = libro.genero;
        document.getElementById("autorModalTitulo")!.textContent = libro.titulo;
        document.getElementById("autorModalAutor")!.textContent = libro.autor;
        document.getElementById("autorModalDesc")!.textContent =
          libro.descripcion || "Descripción no disponible.";
        document.getElementById("autorModalPrecio")!.textContent =
          `$${libro.precio.toLocaleString("es-CO")}`;

        // Campos nuevos
        document.getElementById("autorModalISBN")!.textContent =
          (libro as any).isbn || "No disponible";
        document.getElementById("autorModalPaginas")!.textContent =
          (libro as any).paginas ? `${(libro as any).paginas} páginas` : "No disponible";

        // Botón carrito
        document.getElementById("autorModalBtnCarrito")!.onclick = () => {
          agregarAlCarrito(libro.id, libro.titulo, libro.precio);
        };

        // Abrir modal
        // @ts-ignore
        new bootstrap.Modal(document.getElementById("modalAutorLibro")).show();
      });
    });
  });
</script>
<style>
  .bev-author-profile {
    background-color: var(--pr-gray-1000);
    min-height: 100vh;
    color: var(--pr-gray-900);
  }

  /* Link */
  .bev-back-link {
    color: var(--pr-gray-900);
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .bev-back-link:hover {
    transform: translateX(-5px);
    opacity: 0.7;
  }

  /* Avatar */
  .bev-author-detail-avatar {
    width: 280px;
    height: 280px;
  }

  .bev-author-detail-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .bev-avatar-fallback-large {
    width: 100%;
    height: 100%;
    background: var(--pr-gray-400);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: bold;
    color: var(--pr-gray-900);
  }

  /* Tipografía */
  h1, h3, h6 {
    color: var(--pr-gray-900);
  }

  .bev-author-bio {
    color: var(--pr-gray-900);
    line-height: 1.6;
  }

  .bev-author-subtext {
    color: var(--pr-gray-900);
    font-size: 0.9rem;
  }

  /* Precio */
  .bev-book-price {
    color: var(--pr-gray-900);
    font-weight: 700;
    margin: 0;
  }

  /* Divider */
  .bev-divider {
    height: 4px;
    width: 60px;
    background-color: var(--pr-gray-900);
    border-radius: 2px;
  }

  /* Tag (negro sólido) */
  .bev-section-tag {
    background-color: var(--pr-gray-900);
    color: var(--pr-gray-1000);
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
  }

  /* Cards negras */
  .bev-book-card-v2 {
    background-color: var(--pr-gray-900);
    border: 1px solid var(--pr-gray-900);
    border-radius: 12px;
    transition: all 0.3s ease;
    padding: 12px;
  }

  .bev-book-card-v2:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }

  /* Dentro de cards (texto blanco para contraste) */
  .bev-book-card-v2 h6,
  .bev-book-card-v2 .bev-book-price {
    color: var(--pr-white);
  }

  .bev-book-cover-v2 {
    transition: transform 0.3s ease;
  }

  .bev-book-card-v2:hover .bev-book-cover-v2 {
    transform: translateY(-8px);
  }

  /* Línea */
  hr {
    border-color: var(--pr-gray-900);
  }
</style>