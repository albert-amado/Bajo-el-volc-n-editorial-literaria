---
import Layout from "../layouts/layout.astro";
---

<Layout
  title="Contacto"
  description="Contáctanos para consultas sobre nuestro catálogo, envíos o cualquier pregunta sobre Bajo el Volcán Editorial Literaria."
  noindex={true}
>
  <main class="bev-contacto mt-5 pt-5">
    <div class="container">
      <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
          <span class="bev-section-tag">Escríbenos</span>
          <h1 class="display-4 bev-display-4 fw-bold mt-3 mb-4">Contacto</h1>
          <div class="bev-divider mx-auto mb-4"></div>
          <p class="lead bev-lead">¿Tienes dudas? Estamos aquí para escucharte.</p>
        </div>
      </div>

      <div class="row g-5 mb-5">
        <div class="col-12 col-lg-5">
          <div class="bev-contact-info h-100 p-4">
            <div class="text-center mb-4">
              <img
                src="/assets/img/ui/logo.webp"
                alt="Bajo el Volcán"
                class="bev-contact-logo"
                onerror="this.style.display='none'"
              />
            </div>

            <hr class="border-secondary mb-4" />

            <ul class="list-unstyled bev-contact-list">
              <li class="d-flex align-items-start gap-3 mb-4">
                <div class="bev-contact-icon">
                  <i class="bi bi-whatsapp"></i>
                </div>
                <div>
                  <p class="bev-contact-label">WhatsApp</p>
                  <a
                    href="https://wa.me/573144559506"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bev-contact-value"
                  >
                    +57 314 455 9506
                  </a>
                </div>
              </li>

              <li class="d-flex align-items-start gap-3 mb-4">
                <div class="bev-contact-icon">
                  <i class="bi bi-envelope"></i>
                </div>
                <div>
                  <p class="bev-contact-label">Correo</p>
                  <a
                    href="mailto:bajoelvolcane@gmail.com"
                    class="bev-contact-value"
                  >
                    bajoelvolcane@gmail.com
                  </a>
                </div>
              </li>

              <li class="d-flex align-items-start gap-3 mb-4">
                <div class="bev-contact-icon">
                  <i class="bi bi-instagram"></i>
                </div>
                <div>
                  <p class="bev-contact-label">Instagram</p>
                  <a
                    href="https://www.instagram.com/bajoelvolcane"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bev-contact-value"
                  >
                    @bajoelvolcane
                  </a>
                </div>
              </li>

              <li class="d-flex align-items-start gap-3 mb-4">
                <div class="bev-contact-icon">
                  <i class="bi bi-geo-alt"></i>
                </div>
                <div>
                  <p class="bev-contact-label">Ubicación</p>
                  <p class="bev-contact-value mb-0">
                    Duitama, Boyacá — Colombia
                  </p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <div class="col-12 col-lg-7">
          <div class="bev-contact-form p-4 p-lg-5 h-100">
            <h4 class="fw-bold mb-4">Dejanos tu mensaje</h4>

            <div id="formContacto">
              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <label class="bev-form-label" for="inputNombre">Nombre</label>
                  <input
                    type="text"
                    id="inputNombre"
                    class="bev-form-input"
                    placeholder="Tu nombre"
                    required
                  />
                </div>

                <div class="col-12 col-md-6">
                  <label class="bev-form-label" for="inputCorreo"
                    >Correo electrónico</label
                  >
                  <input
                    type="email"
                    id="inputCorreo"
                    class="bev-form-input"
                    placeholder="tu@correo.com"
                    required
                  />
                </div>

                <div class="col-12">
                  <label class="bev-form-label" for="inputAsunto">Asunto</label>
                  <input
                    type="text"
                    id="inputAsunto"
                    class="bev-form-input"
                    placeholder="¿En qué podemos ayudarte?"
                  />
                </div>

                <div class="col-12">
                  <label class="bev-form-label" for="inputMensaje"
                    >Mensaje</label
                  >
                  <textarea
                    id="inputMensaje"
                    class="bev-form-input"
                    rows="5"
                    placeholder="Escribe tu mensaje aquí..."
                    required></textarea>
                </div>

                <div class="col-12">
                  <button
                    type="button"
                    id="btnEnviar"
                    class="btn bev-btn-submit w-100"
                  >
                    <i class="bi bi-send me-2"></i>Enviar mensaje
                  </button>
                </div>

                <div class="col-12 text-center">
                  <a
                    href="https://wa.me/573144559506"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="bev-contact-value"
                  >
                    También puedes escribirnos por WhatsApp: +57 314 455 9506
                  </a>
                </div>

                <div class="col-12">
                  <div id="formMensaje" class="bev-form-feedback d-none"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const feedback = document.getElementById("formMensaje");
    const destinationEmail = "bajoelvolcane@gmail.com";

    document
      .getElementById("btnEnviar")
      ?.addEventListener("click", () => {
        const nombre = (
          document.getElementById("inputNombre") as HTMLInputElement
        ).value.trim();
        const correo = (
          document.getElementById("inputCorreo") as HTMLInputElement
        ).value.trim();
        const asunto = (
          document.getElementById("inputAsunto") as HTMLInputElement
        ).value.trim();
        const mensaje = (
          document.getElementById("inputMensaje") as HTMLTextAreaElement
        ).value.trim();

        if (!nombre || !correo || !mensaje) {
          showFeedback("Por favor completa los campos obligatorios.", false);
          return;
        }

        const subject = encodeURIComponent(asunto || "Mensaje desde contacto web");
        const body = encodeURIComponent(
          `Nombre: ${nombre}\nCorreo: ${correo}\n\nMensaje:\n${mensaje}`,
        );

        window.location.href = `mailto:${destinationEmail}?subject=${subject}&body=${body}`;
        showFeedback("Abrimos tu correo para enviar el mensaje.", true);
      });

    function showFeedback(msg: string, ok: boolean) {
      if (!feedback) return;
      feedback.classList.remove(
        "d-none",
        "bev-feedback-ok",
        "bev-feedback-error",
      );
      feedback.classList.add(ok ? "bev-feedback-ok" : "bev-feedback-error");
      feedback.textContent = msg;
    }
  });
</script>

<style>
  .bev-contacto {
    background-color: transparent;
    min-height: 100vh;
    color: var(--pr-gray-900);
  }

  .bev-contact-info,
  .bev-contact-form {
    background-color: var(--pr-white);
    border: 1px solid var(--pr-gray-200);
    border-radius: 12px;
  }

  .bev-contact-logo {
    max-width: 140px;
    height: auto;
  }

  .bev-contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--pr-gray-100);
    color: var(--pr-gray-900);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    flex-shrink: 0;
  }

  .bev-contact-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--pr-gray-700);
    margin-bottom: 0.2rem;
    font-weight: 600;
  }

  .bev-contact-value {
    color: var(--pr-gray-900);
    text-decoration: none;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .bev-contact-value:hover {
    opacity: 0.7;
  }

  .bev-form-label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--pr-gray-700);
    margin-bottom: 0.4rem;
    font-weight: 600;
  }

  .bev-form-input {
    width: 100%;
    background-color: var(--pr-white);
    border: 1px solid var(--pr-gray-200);
    border-radius: 8px;
    color: var(--pr-gray-900);
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    outline: none;
    resize: vertical;
  }

  .bev-form-input::placeholder {
    color: var(--pr-gray-400);
  }

  .bev-form-input:focus {
    border-color: var(--pr-gray-900);
    box-shadow: 0 0 0 2px var(--pr-glass-dark);
  }

  .bev-btn-submit {
    background-color: var(--pr-gray-900);
    color: var(--pr-white);
    border: none;
    padding: 0.75rem;
    border-radius: 8px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .bev-btn-submit:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .bev-form-feedback {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    text-align: center;
  }

  .bev-feedback-ok {
    background-color: var(--pr-gray-50);
    border: 1px solid var(--pr-gray-200);
    color: var(--pr-gray-900);
  }

  .bev-feedback-error {
    background-color: var(--status-error-bg);
    border: 1px solid var(--status-error-border);
    color: var(--status-error-text);
  }

  @media (max-width: 575px) {
    .bev-contact-info,
    .bev-contact-form {
      padding: 1.25rem !important;
    }

    .bev-contact-logo {
      max-width: 110px;
    }

    .bev-contact-value {
      font-size: 0.9rem;
      word-break: break-word;
    }

    .bev-contact-icon {
      width: 36px;
      height: 36px;
      font-size: 0.95rem;
    }

    .bev-form-input {
      font-size: 0.92rem;
    }
  }
</style>
