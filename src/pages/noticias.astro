---
import Layout from "../layouts/layout.astro";
import {
  categoriasNoticias,
  formatNewsDate,
  getCategoriaColorClass,
  noticiasPreparadas,
} from "../utils/noticias.js";
---

<Layout
  title="Noticias"
  description="Eventos, lanzamientos, convocatorias y todo lo que sucede en Bajo el Volcán Editorial Literaria."
>
  <main class="bev-noticias mt-5 pt-5">
    <div class="container">
      <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
          <span class="bev-section-tag">Actualidad</span>
          <h1 class="display-4 bev-display-4 fw-bold mt-3 mb-4">Noticias</h1>
          <div class="bev-divider mx-auto mb-4"></div>
          <p class="lead bev-lead">
            Eventos, lanzamientos y todo lo que pasa en Bajo el Volcán.
          </p>
        </div>
      </div>

      <div class="row mb-4">
        <div class="col-12 d-flex flex-wrap gap-2 justify-content-center">
          <button class="bev-filtro active" data-filtro="todos">Todos</button>
          {
            categoriasNoticias.map((categoria) => (
              <button class="bev-filtro" data-filtro={categoria.key}>
                {categoria.label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="row g-4 mb-5" id="noticiasGrid">
        {
          noticiasPreparadas.map((noticia) => (
            <div
              class="col-12 col-md-6 col-lg-4 bev-noticia-item"
              data-categoria={noticia.categoriaKey}
            >
              <a
                href={`/noticias/${noticia.slug}`}
                class="text-decoration-none d-block h-100"
              >
                <div class="bev-noticia-card h-100">
                  <div class="bev-noticia-img">
                    {noticia.imagen ? (
                      <img
                        src={noticia.imagen}
                        alt={noticia.titulo}
                        loading="lazy"
                        onerror="this.parentElement.classList.add('bev-img-fallback')"
                      />
                    ) : (
                      <div class="bev-img-placeholder">
                        <i class="bi bi-newspaper" />
                      </div>
                    )}
                    <span
                      class={`bev-categoria-badge ${getCategoriaColorClass(noticia.categoriaKey)}`}
                    >
                      {noticia.categoriaLabel}
                    </span>
                  </div>
                  <div class="bev-noticia-body">
                    <p class="bev-noticia-fecha mb-2">
                      <i class="bi bi-calendar3 me-1" />
                      {formatNewsDate(noticia.fecha)}
                    </p>
                    <h5 class="bev-noticia-titulo mb-2">
                      {noticia.titulo || "Sin título"}
                    </h5>
                    <p class="bev-noticia-resumen mb-0">
                      {noticia.resumen || "Sin resumen disponible."}
                    </p>
                    <p class="bev-noticia-cta mb-0 mt-3">
                      Conoce mas <i class="bi bi-arrow-right-short" aria-hidden="true" />
                    </p>
                  </div>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filtros = document.querySelectorAll(".bev-filtro");
    const items = document.querySelectorAll<HTMLElement>(".bev-noticia-item");

    filtros.forEach((btn) => {
      btn.addEventListener("click", () => {
        filtros.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const filtro = btn.getAttribute("data-filtro");
        items.forEach((item) => {
          const categoria = item.getAttribute("data-categoria");
          item.style.display =
            filtro === "todos" || categoria === filtro ? "" : "none";
        });
      });
    });
  });
</script>

<style>
  .bev-noticias {
    background-color: transparent;
    min-height: 100vh;
    color: var(--pr-gray-900);
  }

  .bev-filtro {
    background: transparent;
    border: 1px solid var(--pr-glass-dark-15);
    color: var(--pr-gray-900);
    padding: 6px 18px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .bev-filtro:hover,
  .bev-filtro.active {
    background-color: var(--pr-gray-900);
    border-color: var(--pr-gray-900);
    color: var(--pr-white);
  }

  .bev-noticia-card {
    background-color: var(--pr-white);
    border: 1px solid var(--pr-gray-900);
    border-radius: 12px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .bev-noticia-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
  }

  .bev-noticia-img {
    position: relative;
    height: 200px;
    overflow: hidden;
    background-color: var(--pr-gray-50);
  }

  .bev-noticia-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .bev-noticia-card:hover .bev-noticia-img img {
    transform: scale(1.05);
  }

  .bev-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--pr-gray-200);
  }

  .bev-categoria-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .bev-cat-evento {
    background-color: var(--pr-gray-400);
    color: var(--pr-gray-900);
  }
  .bev-cat-lanzamiento {
    background-color: var(--pr-gray-900);
    color: var(--pr-white);
  }
  .bev-cat-convocatoria {
    background-color: var(--pr-gray-100);
    color: var(--pr-gray-900);
  }
  .bev-cat-entrevista {
    background-color: var(--pr-gray-700);
    color: var(--pr-white);
  }
  .bev-cat-premio {
    background-color: var(--pr-gray-200);
    color: var(--pr-gray-900);
  }

  .bev-noticia-fecha {
    font-size: 0.78rem;
    color: var(--pr-gray-700);
  }

  .bev-noticia-titulo {
    color: var(--pr-gray-900);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
  }

  .bev-noticia-resumen {
    font-size: 0.88rem;
    color: var(--pr-gray-700);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bev-noticia-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--pr-gray-900);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .bev-noticia-card:hover .bev-noticia-cta {
    border-bottom-color: var(--pr-gray-900);
    transform: translateX(2px);
  }

  .bev-noticia-body {
    padding: 1.25rem;
  }

  @media (max-width: 767px) {
    .bev-noticia-img {
      height: 170px;
    }

    .bev-noticia-body {
      padding: 1rem;
    }

    .bev-noticia-titulo {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 575px) {
    .bev-filtro {
      padding: 0.45rem 0.9rem;
      font-size: 0.72rem;
    }

    .bev-noticia-img {
      height: 155px;
    }
  }
</style>
