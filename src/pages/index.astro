---
import Layout from '../layouts/layout.astro';
import CarruselHero from '../components/carruselhero.astro';
import CarruselLibros from '../components/carrusellibros.astro';
import Autores from '../components/autores.astro';
---

<Layout title="Bajo el Volcán — Inicio">
  <CarruselHero />
  
  <section class="py-5">
    <div class="container">
      <h2 class="bev-section-title text-center mb-4">Libros Destacados</h2>
      <CarruselLibros />
    </div>
  </section>

  <section class="bev-section-dark py-5">
    <div class="container">
      <h2 class="bev-section-title text-white text-center mb-5">Nuestros Autores</h2>
      <Autores />
    </div>
  </section>
</Layout>