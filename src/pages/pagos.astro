---
import Layout from "../layouts/layout.astro";
---

<Layout title="Pagos - Bajo el Volcán">
  <main class="bev-pagos mt-5 pt-5">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8 text-center">
          <h1 class="bev-pagos-titulo fw-bold mb-4">Realiza tu pago</h1>

          <p class="bev-pagos-lead lead mb-5 px-md-5">
            Realiza el pago de tu libro con el siguiente código QR<br />
            y envía el comprobante al siguiente número.
          </p>

          <!-- QR -->
          <div class="bev-qr-box mx-auto mb-5">
            <img
              src="/assets/img/pagos/pagos.webp"
              alt="Código QR de pago - Bajo el Volcán Ediciones"
              class="img-fluid bev-qr-img"
            />
            <p class="mt-4 mb-0 bev-qr-label">Bajo el Volcán Ediciones</p>
          </div>

          <div class="bev-pago-info">
            <p class="bev-pago-subtitle fw-semibold mb-3">
              Envía el comprobante a:
            </p>
            <a
              href="https://wa.me/573144559506"
              target="_blank"
              rel="noopener noreferrer"
              class="bev-whatsapp-btn d-inline-flex align-items-center gap-3 px-5 py-4 rounded-4"
            >
              <i class="bi bi-whatsapp bev-wp-icon"></i>
              <div class="text-start">
                <span class="d-block bev-wp-numero fw-bold"
                  >+57 314 455 9506</span
                >
                <small class="bev-wp-label">• Abre WhatsApp</small>
              </div>
            </a>
          </div>

          <div class="mt-5 pt-4 border-top">
            <p class="bev-pagos-footer text-muted">
              Una vez enviado el comprobante, te confirmaremos el pago en pocos
              minutos.<br />
              ¡Gracias por elegir Bajo el Volcán!
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .bev-pagos {
    background-color: var(--pr-gray-1000);
    min-height: 100vh;
    color: var(--pr-gray-900);
  }

  .bev-pagos-titulo {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .bev-pagos-lead {
    font-size: clamp(1.1rem, 2vw, 1.65rem);
    line-height: 1.55;
  }

  /* QR */
  .bev-qr-box {
    background: var(--pr-white);
    padding: 2.5rem;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    display: inline-block;
    max-width: 560px;
    width: 100%;
  }

  .bev-qr-img {
    max-width: 480px;
    width: 100%;
    border-radius: 16px;
  }

  .bev-qr-label {
    font-size: 1.05rem;
    color: var(--pr-gray-700);
  }
  .bev-pago-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.55rem);
  }

  .bev-whatsapp-btn {
    background-color: #25d366;
    color: white;
    text-decoration: none;
    transition:
      background-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
    border: none;
  }

  .bev-whatsapp-btn:hover {
    background-color: #20b958;
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(37, 211, 102, 0.4);
    color: white;
  }

  .bev-wp-icon {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .bev-wp-numero {
    font-size: clamp(1.3rem, 3vw, 2rem);
  }

  .bev-wp-label {
    font-size: 1rem;
    color: #d4f5e2;
  }

  .bev-pagos-footer {
    font-size: clamp(0.95rem, 1.5vw, 1.2rem);
  }

  @media (max-width: 576px) {
    .bev-qr-box {
      padding: 1.5rem;
    }

    .bev-whatsapp-btn {
      padding: 1rem 2rem !important;
      gap: 0.75rem !important;
    }
  }
</style>
