---
import libros from "../data/libros.json";
import LibroCard from "./libroCard.astro";
---

<section class="py-5">
  <div class="bev-container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light libros-seccion__tag">
        Colección de Bajo el Volcán
      </span>
      <h2 class="bev-section-title libros-seccion__titulo">Nuestras Novelas</h2>
    </div>

    <div class="libros-grid">
      {libros.map((libro) => (
        <LibroCard
          id={libro.id}
          titulo={libro.titulo}
          autor={libro.autor}
          genero={libro.genero}
          precio={libro.precio}
          imagen={libro.imagen}
          etiqueta={libro.etiqueta}
        />
      ))}
    </div>
  </div>
</section>

<script>
  import { abrirModal } from "../js/modal.js";
  import { agregarAlCarrito } from "../js/carrito.js";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".js-btn-modal").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.getAttribute("data-id");
        if (id) abrirModal(parseInt(id));
      });
    });

    document.querySelectorAll(".js-btn-carrito").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.getAttribute("data-id");
        const titulo = btn.getAttribute("data-titulo");
        const precio = parseFloat(btn.getAttribute("data-precio") || "0");
        if (id && titulo) agregarAlCarrito(id, titulo, precio);
      });
    });
  });
</script>

<style>
  .libros-seccion__tag {
    font-size: 1rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .libros-seccion__titulo {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
  }

  .libros-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 220px));
    gap: 1.5rem;
    justify-content: center;
  }

  @media (max-width: 991px) {
    .libros-grid {
      grid-template-columns: repeat(3, minmax(0, 220px));
    }
  }

  @media (max-width: 639px) {
    .libros-grid {
      grid-template-columns: repeat(2, minmax(0, 180px));
      gap: 0.75rem;
    }
  }
</style>