---

---

<!-- ── MODAL DETALLE DEL LIBRO ── -->
<div class="modal fade" id="modalLibro" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content bev-modal-content">
      <div class="bev-modal-header d-flex justify-content-end">
        <button
          type="button"
          class="btn-close btn-close-white"
          data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-0">
        <div class="row g-0" style="min-height: 520px;">
          <!-- Portada -->
          <div class="col-12 col-md-4 bev-modal-cover">
            <img
              id="modalPortada"
              src=""
              alt=""
              style="width:100%; height:100%; object-fit:cover; display:block;"
            />
          </div>

          <!-- Info -->
          <div
            class="col-12 col-md-8 d-flex flex-column p-4 p-lg-5"
            style="background: var(--bev-cream);"
          >
            <div class="d-flex align-items-center gap-2 mb-2">
              <span
                id="modalEtiqueta"
                class="bev-etiqueta"
                style="position:static; font-size:0.7rem; padding:3px 10px;"
              ></span>
              <span
                id="modalGenero"
                class="bev-eyebrow mb-0"
                style="font-size:0.72rem;"></span>
            </div>

            <h2 id="modalTitulo" class="bev-modal-titulo"></h2>
            <p id="modalAutorNombre" class="bev-modal-autor"></p>
            <p id="modalDesc" class="bev-modal-desc flex-grow-1 mb-4"></p>

            <div
              class="d-flex align-items-center justify-content-between flex-wrap gap-3 mt-auto pt-3"
              style="border-top: 1px solid var(--bev-cream-dk);"
            >
              <span id="modalPrecio" class="bev-modal-precio"></span>
              <button id="modalBtnCarrito" class="btn bev-btn-gold">
                <i class="bi bi-bag-plus me-2"></i>Agregar al carrito
              </button>
            </div>
            <!-- SECCIÓN AUTOR -->
            <div
              class="mt-4 pt-4"
              style="border-top: 1px solid var(--bev-cream-dk);"
            >
              <div class="d-flex align-items-start gap-3">
                <img
                  id="modalAutorFoto"
                  src=""
                  alt=""
                  onerror="this.style.display='none'; document.getElementById('modalAutorFallback').style.display='flex';"
                  style="width:70px; height:70px; border-radius:50%; object-fit:cover; object-position:top; border:2px solid var(--bev-gold); flex-shrink:0;"
                />
                <div
                  id="modalAutorFallback"
                  style="display:none; width:70px; height:70px; border-radius:50%; background:var(--bev-charcoal); border:2px solid var(--bev-gold); flex-shrink:0; align-items:center; justify-content:center; font-size:1.2rem; color:var(--bev-gold); font-weight:700;"
                >
                  <span id="modalAutorIniciales"></span>
                </div>
                <div>
                  <p
                    style="font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--bev-gold); margin-bottom:0.2rem;"
                  >
                    Autor
                  </p>
                  <p
                    id="modalAutorNombreDetalle"
                    style="font-weight:700; color:var(--bev-ink); margin-bottom:0.3rem; font-size:0.95rem;"
                  >
                  </p>
                </div>
              </div>
            </div>
            Autor
          </div>
          <p
            id="modalAutorNombreDetalle"
            style="font-weight:700; color:var(--bev-ink); margin-bottom:0.3rem; font-size:0.95rem;"
          >
          </p>
          <p
            id="modalAutorBio"
            style="font-size:0.82rem; color:var(--bev-charcoal); line-height:1.6; margin:0;"
          >
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
