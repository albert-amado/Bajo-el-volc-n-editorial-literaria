---

<footer class="bev-footer pt-5 pb-3">
  <div class="container">
    <div class="row g-4 text-center text-md-start">
      <div class="col-12 col-md-4">
        <p class="bev-footer-brand">BAJO EL VOLCÁN</p>
        <p class="bev-footer-text">
          Editorial literaria independiente.<br />
          Literatura latinoamericana contemporánea.
        </p>
      </div>

      <div class="col-12 col-md-4">
        <p class="bev-footer-heading">Contacto</p>
        <a
          href="mailto:bajoelvolcane@gmail.com"
          class="bev-footer-text bev-footer-link"
        >
          bajoelvolcane@gmail.com
        </a>
      </div>

      <div
        class="col-12 col-md-4 d-flex align-items-center justify-content-center justify-content-md-start"
      >
        <a
          href="https://www.instagram.com/bajoelvolcane"
          target="_blank"
          rel="noopener noreferrer"
          class="bev-footer-link d-flex align-items-center gap-2"
        >
          <i class="bi bi-instagram"></i>
          <i>@bajoelvolcane</i>
        </a>
      </div>
    </div>

    <hr class="bev-footer-hr mt-4" />
    <p class="bev-footer-copy text-center mb-0">
      © 2025 Bajo el Volcán Editorial. Todos los derechos reservados.
    </p>
  </div>
</footer>

<style>
  .bev-footer {
    background-color: var(--pr-gray-900);
    border-top: 2px solid var(--pr-gray-400);
  }

  .bev-footer-brand {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--pr-gray-400);
    margin-bottom: 0.5rem;
  }

  .bev-footer-heading {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pr-white);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .bev-footer-text {
    font-size: 0.9rem;
    color: var(--pr-gray-400);
    line-height: 1.7;
    margin: 0;
  }

  .bev-footer-link {
    color: var(--pr-gray-400);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .bev-footer-link:hover {
    color: var(--pr-white);
  }

  .bev-footer-hr {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .bev-footer-copy {
    font-size: 0.78rem;
    color: var(--pr-gray-400);
  }
</style>
