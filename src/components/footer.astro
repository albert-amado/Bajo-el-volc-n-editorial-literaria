---
<footer class="bev-footer pt-5 pb-3">
  <div class="container">
    <div class="row g-4">

      <div class="col-md-4">
        <p class="bev-footer-brand">BAJO EL VOLCÁN</p>
        <p class="bev-footer-text">
          Editorial literaria independiente.<br />
          Literatura latinoamericana contemporánea.
        </p>
      </div>

      <div class="col-md-4">
        <p class="bev-footer-heading">Contacto</p>
        <p class="bev-footer-text">bajoelvolcane@gmail.com</p>
      </div>

      <div class="col-md-4 d-flex align-items-center">
        <a href="https://www.instagram.com/bajoelvolcane" class="bev-topbar-link">
          <i class="bi bi-instagram"></i>
          <i>@bajoelvolcane</i>
        </a>
      </div>

    </div>

    <hr class="bev-footer-hr mt-4" />
    <p class="bev-footer-copy text-center mb-0">
      © 2025 Bajo el Volcán Editorial. Todos los derechos reservados.
    </p>
  </div>
</footer>

<style>
  .bev-footer {
    background-color: var(--pr-gray-900);
    border-top: 2px solid var(--pr-gray-400);
  }

  .bev-footer-brand {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--pr-gray-400);
    margin-bottom: 0.5rem;
  }

  .bev-footer-heading {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pr-white);
    margin-bottom: 1rem;
  }

  .bev-footer-text {
    font-size: 0.9rem;
    color: var(--pr-gray-400);
    line-height: 1.7;
  }

  .bev-footer-hr {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .bev-footer-copy {
    font-size: 0.78rem;
    color: var(--pr-gray-400);
  }
</style>