<footer class="bev-footer pt-5 pb-3">
  <div class="container">
    <div class="row g-4">
      <div class="col-md-4">
        <p class="bev-footer-brand">BAJO EL VOLCÁN</p>
        <p class="bev-footer-text">
          Editorial literaria independiente.<br />Literatura latinoamericana
          contemporánea.
        </p>
      </div>
      <div class="col-md-4">
        <p class="bev-footer-heading">Contacto</p>
        <p class="bev-footer-text">bajoelvolcane@gmail.com<br /></p>
      </div>
    </div>
    <hr class="bev-footer-hr mt-4" />
    <p class="bev-footer-copy text-center mb-0">
      © 2025 Bajo el Volcán Editorial. Todos los derechos reservados.
    </p>
  </div>
</footer>
<style>
.bev-footer {
  background-color: var(--bev-ink);
  border-top: 2px solid var(--bev-gold);
}

.bev-footer-brand {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--bev-gold);
  margin-bottom: 0.5rem;
}

.bev-footer-heading {
  font-size: 0.72rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--bev-cream);
  margin-bottom: 1rem;
}

.bev-footer-text {
  font-size: 0.9rem;
  color: var(--bev-ash);
  line-height: 1.7;
}

.bev-footer-links a {
  display: block;
  color: var(--bev-ash);
  text-decoration: none;
  font-size: 0.9rem;
  margin-bottom: 0.4rem;
  transition: color 0.2s;
}

.bev-footer-links a:hover { color: var(--bev-gold); }

.bev-footer-hr   { border-color: rgba(255,255,255,0.08); }
.bev-footer-copy { font-size: 0.78rem; color: var(--bev-ash); }

</style>