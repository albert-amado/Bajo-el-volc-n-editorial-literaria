<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="bev-categorias-container">
      <p class="bev-categorias-titulo text-center text-lg-start">CATEGORÍAS</p>
      <ul class="bev-categorias-lista-horizontal" id="listaCategorias">
        <li class="bev-categoria-item activo" data-categoria="todos">Todos</li>
        <li class="bev-categoria-item" data-categoria="nuevo">Nuevos</li>
        <li class="bev-categoria-item" data-categoria="destacado">
          Destacados
        </li>
        <li class="bev-categoria-item" data-categoria="preventa">Preventa</li>
        <li class="bev-categoria-item" data-categoria="Misterio">Misterio</li>
        <li class="bev-categoria-item" data-categoria="Romance">Romance</li>
        <li class="bev-categoria-item" data-categoria="Novela">Novela</li>
        <li class="bev-categoria-item" data-categoria="Filosofia">Filosofía</li>
        <li class="bev-categoria-item" data-categoria="Crimen">Crimen</li>
      </ul>
    </div>
  </div>
</div>
<style is:global>
  .bev-categorias-container {
    background: var(--pr-white);
    padding: 1.5rem 1.25rem;
    border-radius: 0;
    border: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .bev-categorias-titulo {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.5em;
    color: var(--pr-black);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--pr-gray-100);
    filter: drop-shadow(0 0 4px var(--pr-glass-light-30));
  }

  .bev-categorias-lista-horizontal {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .bev-categoria-item {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--pr-black);
    background: transparent;
    padding: 0.45rem 0;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.25s ease;
    border: none;
    width: 100%;
    text-align: left;
  }

  .bev-categoria-item:hover {
    color: var(--pr-gray-1200);
  }
  
  .bev-categoria-item.activo {
    background: transparent;
    color: var(--pr-black);
    font-weight: 700;
    border: none;
  }

  @media (max-width: 991px) {
    .bev-categorias-lista-horizontal {
      gap: 0.25rem;
    }
    .bev-categoria-item {
      font-size: 0.85rem;
      padding: 0.35rem 0;
    }
  }
</style>
