<style>
  .bev-navbar {
  background-color: var(--navbar-bg);
  border-bottom: 1px solid var(--navbar-border);
  padding: 0.75rem 0;
  backdrop-filter: blur(6px); /* 🔥 efecto pro */
}

/* Logo */
.bev-navbar .navbar-brand img {
  width: 80px;
  height: 100px;
  object-fit: contain;
  filter: drop-shadow(0 0 4px var(--navbar-logo-glow));
  transition: transform 0.3s ease;
}

.bev-navbar .navbar-brand img:hover {
  transform: scale(1.05);
}

/* Marca */
.bev-brand-main {
  font-family: 'Lato', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--navbar-text);
}

.bev-brand-sub {
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--navbar-text-muted);
}

/* Links */
.bev-navbar .nav-link {
  position: relative;
  color: var(--navbar-text) !important;
  font-size: 0.82rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding-bottom: 6px;
  transition: color 0.25s ease;
}

/* 🔥 NUEVA ANIMACIÓN (línea elegante) */
.bev-navbar .nav-link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 0%;
  height: 1.5px;
  background-color: var(--navbar-accent);
  transition: width 0.3s ease;
}

.bev-navbar .nav-link:hover::after,
.bev-navbar .nav-link.active::after {
  width: 100%;
}

.bev-navbar .nav-link:hover {
  color: var(--navbar-text) !important;
}

/* Carrito */
.bev-cart-badge {
  position: absolute;
  top: -4px;
  right: -8px;
  background: var(--navbar-text);
  color: var(--pr-gray-900);
  font-size: 0.65rem;
  font-weight: 700;
  width: 17px;
  height: 17px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>