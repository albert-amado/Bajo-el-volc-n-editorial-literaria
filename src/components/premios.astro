<div class="bev-premios">
  <div class="container-fluid d-flex justify-content-center">

    <div class="bev-promo-wrapper text-center">

      <!-- TEXTO -->
      <div class="bev-promo-text">
        "Tu talento merece ser descubierto. Participa en el Primer Premio Nacional de Novela."
      </div>

      <!-- IMAGEN -->
      <img
        src="/assets/img/carrusels/premionacional.webp"
        alt="Premio Nacional de Novela"
        class="bev-promo-img"/>

      <!-- BOTÓN -->
      <a class="btn bev-btn-premio"
        href="/assets/img/doc/bases_premio_nacional_de_novela.pdf"
        target="_blank">
        participa
      </a>

    </div>

  </div>
</div>
</div>
  </div>
</div>

<style>
  .bev-premios {
    background-color: var(--pr-gray-1000);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 9rem 0 1.5rem;
  }

  .bev-promo-wrapper {
    position: relative;
    line-height: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.9);
  }

  /* IMAGEN MUCHO MÁS GRANDE */
  .bev-promo-img {
  display: block;
  width: 100%;
  height: auto;
}

  /* TEXTO ENCIMA DE LA IMAGEN (centrado y en negrita) */
  
.bev-promo-text {
  display: block; /* 🔥 clave */
  width: 100%;

  text-align: center;

  font-family: "Lato", sans-serif;
  font-size: clamp(2rem, 3vw, 2.8rem);
  font-weight: 700;
  color: var(--pr-gray-900);

  background-color: var(--pr-gray-1400);
  padding: 3rem 2rem; /* alto tipo sección */

  margin-bottom: 4rem;
  position: relative;

  box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}

  /* BOTÓN EN LA POSICIÓN ORIGINAL (izquierda) + más grande */
  .bev-btn-premio {
    position: absolute;
    bottom: 50px;
    left: 20%;
    transform: translateX(-50%);
    background-color: var(--pr-gray-1400);
    color: var(--pr-white);
    border: 2px solid rgba(255, 255, 255, 0.7);
    padding: 1.1rem 2.8rem;
    font-size: 1.15rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 4px;
    backdrop-filter: blur(6px);
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .bev-btn-premio:hover {
    background-color: rgba(0, 0, 0, 0.9);
    border-color: var(--pr-white);
    color: var(--pr-white);
    transform: translateX(-50%) scale(1.05);
  }

  .bev-btn-premio::after {
    content: "";
    position: absolute;
    bottom: 8px;
    left: 50%;
    width: 0%;
    height: 2px;
    background: var(--pr-white);
    transform: translateX(-50%);
    transition: width 0.3s ease;
  }

  .bev-btn-premio:hover::after {
    width: 65%;
  }

  @media (max-width: 768px) {
    .bev-promo-text {
      font-size: 1.9rem;
      max-width: 90%;
    }

    .bev-promo-img {
      min-width: 500px;     /* ajustado para móvil */
      max-height: 850px;
    }

    .bev-btn-premio {
      padding: 0.9rem 2.2rem;
      font-size: 1.05rem;
      bottom: 35px;
    }
  }
</style>