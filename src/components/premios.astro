---
<div class="bev-topbar-footer">
  <div class="container d-flex justify-content-center align-items-center">
    
    <div class="bev-promo-wrapper">
      <img
        src="/assets/img/carrusels/premionacional.png"
        alt="Recuadro premio nacional"
        class="bev-promo-img"
      />

      <a
        class="btn bev-btn-premio-banner" 
        href="/assets/img/doc/bases_premio_nacional_de_novela.pdf"
        target="_blank">
        Bases premio novela
      </a>
    </div>

  </div>
</div>

<style is:global>
  .bev-topbar-footer {
    background-color: var(--bev-gold);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .bev-promo-wrapper {
    position: relative;
    display: inline-block;
    line-height: 0;
    /* Opcional: sombra para que resalte sobre el fondo oscuro */
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .bev-promo-img {
    display: block;
    width: auto;

    max-height: 500px; 
    min-width: 500px; 
    height: auto;
    object-fit: contain;
  }

  .bev-btn-premio-banner {
    position: absolute;
    bottom: 50px; /* Distancia desde el borde inferior de la imagen */
    left: 20%;
    transform: translateX(-50%);
    
    /* Estilo del botón */
    color: var(--bev-gold);
    border: 2px solid var(--bev-gold); /* Borde un poco más grueso por el tamaño */
    background-color: rgba(0, 0, 0, 0.8); /* Fondo más oscuro para que resalte */
    font-size: 0.9rem; /* Texto más legible para imagen grande */
    padding: 0.4rem 1.2rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .bev-btn-premio-banner:hover {
    background-color: var(--bev-gold);
    color: var(--bev-ink);
  }

  /* Ajuste para móviles: Que no se salga de la pantalla */
  @media (max-width: 768px) {
    .bev-promo-img {
      max-height: 150px;
    }
    .bev-btn-premio-banner {
      font-size: 0.7rem;
      padding: 0.3rem 0.8rem;
    }
  }
</style>