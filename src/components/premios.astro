<div class="bev-premios">
  <div class="bev-promo-wrapper text-center mx-auto">
    <p class="bev-promo-text">
      Tu talento merece ser descubierto. Participa en el Primer Premio Nacional de Novela.
    </p>

    <div class="bev-promo-img-wrapper">
      <img
        src="/assets/img/carrusels/premionacional.webp"
        alt="Premio Nacional de Novela"
        class="bev-promo-img"
        loading="lazy"
      />
      <div class="bev-btn-premio-wrap">
        <a class="btn bev-btn-premio"
          href="/assets/img/doc/bases.pdf"
          target="_blank"
          rel="noopener noreferrer">
          Bases del premio
        </a>
      </div>
    </div>

    <!--Enlace manuscritos -->
    <div class="bev-promo-contact">
      <h3 class="bev-promo-contact-title">Envía aquí tu manuscrito:</h3>
      <a href="mailto:bajoelvolcane@gmail.com"
        class="bev-footer-text bev-footer-link bev-promo-contact-link"
      >
        bajoelvolcane@gmail.com
      </a>
    </div>

  </div>
</div>

<style>
  .bev-premios {
    background-color: var(--pr-gray-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 5rem 0 3rem;
  }

  .bev-promo-wrapper {
    max-width: 1200px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
  }

  .bev-promo-text {
    font-family: "Lato", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--pr-gray-50);
    background-color: var(--pr-gray-1400);
    padding: 2.5rem 2rem;
    margin: 0;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
  }

  .bev-promo-img-wrapper {
    position: relative;
    line-height: 0;
  }

  .bev-promo-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .bev-btn-premio-wrap {
    position: absolute;
    bottom: 5%;
    left: 20px;
  }

  .bev-btn-premio {
    background-color: var(--pr-gray-1400);
    color: var(--pr-white);
    border: 2px solid rgba(255, 255, 255, 0.7);
    padding: 0.9rem 2.5rem;
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 4px;
    backdrop-filter: blur(6px);
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .bev-btn-premio:hover {
    background-color: rgba(0, 0, 0, 0.9);
    border-color: var(--pr-white);
    color: var(--pr-white);
    transform: scale(1.05);
  }

  /* --- Sección de contacto --- */
  .bev-promo-contact {
    background-color: var(--pr-gray-1400);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .bev-promo-contact-title {
    font-family: "Lato", sans-serif;
    font-size: clamp(1rem, 2vw, 1.6rem);
    font-weight: 900;
    color: var(--pr-gray-900);
    margin: 0;
  }

  .bev-promo-contact-link {
    font-family: "Lato", sans-serif;
    font-size: clamp(1rem, 2vw, 1.6rem);
    color: var(--pr-white);
    text-decoration: underline;
    transition: opacity 0.2s ease;
  }

  .bev-promo-contact-link:hover {
    opacity: 0.75;
    color: var(--pr-white);
  }

  /* --- Responsive móvil --- */
  @media (max-width: 576px) {
    .bev-premios {
      padding: 3rem 0 2rem;
    }

    .bev-promo-text {
      padding: 1.5rem 1rem;
    }

    .bev-btn-premio {
      padding: 0.65rem 1.5rem;
      font-size: 0.85rem;
    }

    .bev-promo-contact {
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      padding: 1rem 1rem;
    }

    .bev-promo-contact-title {
      font-size: 1rem;
      text-align: center;
    }

    .bev-promo-contact-link {
      font-size: 0.9rem;
      text-align: center;
      word-break: break-all;
    }
  }
</style>