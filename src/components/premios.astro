---
---
<div class="bev-premios">
  <div class="container-fluid d-flex justify-content-center align-items-center">
    <div class="bev-promo-wrapper">
      <img
        src="/assets/img/carrusels/premionacional.png"
        alt="Premio Nacional de Novela"
        class="bev-promo-img"
      />
      
        class="btn bev-btn-premio"
        href="/assets/img/doc/bases_premio_nacional_de_novela.pdf"
        target="_blank"
      >
        Bases premio novela
      </a>
    </div>
  </div>
</div>

<style>
  .bev-premios {
    background-color: var(--pr-gray-1000);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 3rem 0 1.5rem;
  }

  .bev-promo-wrapper {
    position: relative;
    display: inline-block;
    line-height: 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .bev-promo-img {
    display: block;
    width: auto;
    max-height: 900px;
    min-width: 600px;
    height: auto;
    object-fit: contain;
  }

  .bev-btn-premio {
    position: absolute;
    bottom: 50px;
    left: 20%;
    transform: translateX(-50%);
    background-color: rgba(0, 0, 0, 0.65);
    color: var(--pr-white);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: 0.6rem 1.6rem;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    backdrop-filter: blur(4px);
    transition: all 0.3s ease;
  }

  .bev-btn-premio::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 50%;
    width: 0%;
    height: 1px;
    background: var(--pr-white);
    transform: translateX(-50%);
    transition: width 0.3s ease;
  }

  .bev-btn-premio:hover {
    background-color: rgba(0, 0, 0, 0.85);
    border-color: var(--pr-white);
    color: var(--pr-white);
  }

  .bev-btn-premio:hover::after {
    width: 70%;
  }
</style>