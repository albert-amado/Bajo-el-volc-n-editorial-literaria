---

<div class="bev-topbar-footer">
  <div class="container d-flex justify-content-center align-items-center">
    <div class="bev-promo-wrapper">
      <img
        src="/assets/img/carrusels/premionacional.png"
        alt="Recuadro premio nacional"
        class="bev-promo-img"
      />

      <a
        class="btn bev-btn-premio-banner"
        href="/assets/img/doc/bases_premio_nacional_de_novela.pdf"
        target="_blank"
      >
        Bases premio novela
      </a>
    </div>
  </div>
</div>

<style is:global>
  .bev-topbar-footer {
    background-color: var(--pr-gray-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .bev-promo-wrapper {
    position: relative;
    display: inline-block;
    line-height: 0;
    /* Opcional: sombra para que resalte sobre el fondo oscuro */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }

  .bev-promo-img {
    display: block;
    width: auto;

    max-height: 500px;
    min-width: 500px;
    height: auto;
    object-fit: contain;
  }

  .bev-btn-premio-banner {
    position: absolute;
    bottom: 50px; /* Distancia desde el borde inferior de la imagen */
    left: 20%;
    transform: translateX(-50%);
    /* Estética editorial */
    background-color: rgba(0, 0, 0, 0.65);
    color: var(--pr-white);
    border: 1px solid rgba(255, 255, 255, 0.6);

    padding: 0.6rem 1.6rem;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;

    backdrop-filter: blur(4px);

    transition: all 0.3s ease;
  }
  .bev-btn-premio-banner::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 50%;
    width: 0%;
    height: 1px;
    background: var(--pr-white);
    transform: translateX(-50%);
    transition: width 0.3s ease;
  }

  .bev-btn-premio-banner:hover::after {
    width: 70%;
  }

  .bev-btn-premio-banner:hover {
    background-color: rgba(0, 0, 0, 0.85);
    border-color: var(--pr-white);
  }
  .bev-btn-premio-banner:hover {
    background-color: var(--pr-gray-400);
    color: var(--pr-gray-900);
  }
  .bev-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    var(--carousel-overlay-start) 0%,
    var(--carousel-overlay-mid) 40%,
    var(--carousel-overlay-end) 100%
  );
}
@media (max-width: 768px) {
  .bev-slide-content {
    padding-left: 1rem;
  }

  .bev-slide-title {
    font-size: 1.8rem;
    }
  }
</style>