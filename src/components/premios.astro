<div class="bev-premios">
  <div class="bev-promo-wrapper text-center mx-auto">
    <p class="bev-promo-text">
      Tu talento merece ser reconocido. Participa en el Primer Premio Nacional de Novela.
    </p>

    <div class="bev-promo-img-wrapper">
      <img
        src="/assets/img/noticias/premio.webp"
        alt="Premio Nacional de Novela"
        class="bev-promo-img"
        loading="lazy"
      />
      <div class="bev-btn-premio-wrap">
        <a class="btn bev-btn-premio"
          href="/doc/bases.pdf"
          target="_blank"
          rel="noopener noreferrer">
          Bases del premio
        </a>
      </div>
    </div>

    <!--Enlace manuscritos -->
    <div class="bev-promo-contact">
      <h3 class="bev-promo-contact-title">Envía aquí tu manuscrito:</h3>
      <a href="mailto:bajoelvolcane@gmail.com"
        class="bev-footer-text bev-footer-link bev-promo-contact-link"
      >
        bajoelvolcane@gmail.com
      </a>
    </div>

  </div>
</div>

<style>
  .bev-premios {
    background-image: var(--site-bg-image);
    background-repeat: var(--site-bg-repeat);
    background-size: var(--site-bg-size);
    background-position: var(--site-bg-position);
    background-color: var(--pr-white);
    border-bottom: 1px solid var(--pr-glass-light-25);
    padding: 5rem 0 3rem;
  }

  .bev-promo-wrapper {
    max-width: 1200px;
    box-shadow: var(--shadow-strong);
  }

  .bev-promo-text {
    font-family: var(--font-body);
    font-size: clamp(1.4rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--pr-gray-50);
    background-color: var(--pr-gray-1400);
    padding: 2.5rem 2rem;
    margin: 0;
    box-shadow: var(--shadow-strong-md);
  }

  .bev-promo-img-wrapper {
    position: relative;
    line-height: 0;
  }

  .bev-promo-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .bev-btn-premio-wrap {
    position: absolute;
    bottom: 1.1rem;
    left: 1rem;
  }

  .bev-btn-premio {
    background-color: var(--pr-gray-1400);
    color: var(--pr-white);
    border: 2px solid var(--pr-glass-light-70);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    padding: 0.62rem 1.25rem;
    font-size: clamp(0.8rem, 1.1vw, 0.98rem);
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-weight: 700;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .bev-btn-premio:hover {
    background-color: var(--pr-glass-dark-90);
    border-color: var(--pr-white);
    color: var(--pr-white);
    transform: scale(1.05);
  }

  /* --- Sección de contacto --- */
  .bev-promo-contact {
    background-color: var(--pr-gray-1400);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .bev-promo-contact-title {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.6rem);
    font-weight: 900;
    color: var(--pr-gray-900);
    margin: 0;
  }

  .bev-promo-contact-link {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.6rem);
    color: var(--pr-white);
    text-decoration: underline;
    transition: opacity 0.2s ease;
  }

  .bev-promo-contact-link:hover {
    opacity: 0.75;
    color: var(--pr-white);
  }

  /* --- Responsive móvil --- */
  @media (max-width: 576px) {
    .bev-premios {
      padding: 3rem 0 2rem;
    }

    .bev-promo-text {
      padding: 1.5rem 1rem;
    }

    .bev-btn-premio {
      padding: 0.56rem 1rem;
      font-size: 0.78rem;
      letter-spacing: 0.09em;
    }

    .bev-promo-contact {
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      padding: 1rem 1rem;
    }

    .bev-promo-contact-title {
      font-size: 1rem;
      text-align: center;
    }

    .bev-promo-contact-link {
      font-size: 0.9rem;
      text-align: center;
      word-break: break-all;
    }
  }
