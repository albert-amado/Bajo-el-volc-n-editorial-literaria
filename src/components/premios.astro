<div class="bev-topbar-footer">
  <div
    class="container d-flex justify-content-between align-items-center"
  >
    <div class="d-flex align-items-center">
        <img src="/assets/img/carrusels/premionacional.png" alt="Recuadro premio nacional">
    </div>
  </div>
</div>

<style>
  .bev-topbar-footer {
  background-color: var(--bev-topbar);
  border-bottom: 1px solid var(--bev-gold);
  padding: 0.4rem 1rem;
}

.bev-topbar-info {
  color: var(--bev-ash);
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  display: flex;
  align-items: relative;
  gap: 5px;
}

.bev-topbar-link {
  color: var(--bev-ash);
  font-size: 1rem;
  margin-left: 1rem;
  text-decoration: none;
  transition: color 0.2s;
}

.bev-topbar-link:hover { color: var(--bev-gold); }

@media (max-width: 500px) {
  .bev-topbar-info { display: none; }
}
</style>