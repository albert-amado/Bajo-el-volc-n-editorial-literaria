---
---
<section class="py-5 bev-section-light">
  <div class="bev-container">

    <div class="text-center mb-5">
      <span class="bev-section-tag">Colección de Bajo el Volcán</span>
      <h2 class="bev-section-title">Nuestras Novelas</h2>
    </div>

    <div id="librosCarousel" class="carousel slide" data-bs-ride="carousel">

      <div class="carousel-inner" id="librosCarouselInner"></div>

      <!-- Flechas -->
      <button
        class="carousel-control-prev bev-carousel-ctrl"
        type="button"
        data-bs-target="#librosCarousel"
        data-bs-slide="prev"
      >
        <i class="bi bi-chevron-left"></i>
      </button>

      <button
        class="carousel-control-next bev-carousel-ctrl"
        type="button"
        data-bs-target="#librosCarousel"
        data-bs-slide="next"
      >
        <i class="bi bi-chevron-right"></i>
      </button>

    </div>

  </div>
</section>
<style is:global>

/* =========================================================
   🎨 SECCIÓN (gris claro coherente)
========================================================= */
.bev-section-light {
  background-color: var(--bg-subtle);
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light);
}

/* =========================================================
   📦 CARRUSEL
========================================================= */
#librosCarousel {
  position: relative;
  max-width: var(--content-max-width);
  margin: 0 auto;
}

/* IMPORTANTE: espacio para flechas */
.carousel-inner {
  padding: 0 3rem;
}

/* =========================================================
   🎯 FLECHAS FUERA DEL CONTENIDO
========================================================= */
.bev-carousel-ctrl {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  
  width: 40px;
  height: 40px;

  display: flex;
  align-items: center;
  justify-content: center;

  background: var(--pr-white);
  border: 1px solid var(--border-light);
  border-radius: 50%;

  color: var(--bev-gold);
  opacity: 1;
  z-index: 5;

  transition: all 0.3s ease;
}

.bev-carousel-ctrl:hover {
  background: var(--bev-gold);
  color: var(--bev-ink);
}

/* Posición real fuera */
.carousel-control-prev.bev-carousel-ctrl {
  left: -20px;
}

.carousel-control-next.bev-carousel-ctrl {
  right: -20px;
}

/* =========================================================
   🧾 TITULOS
========================================================= */
.bev-section-tag {
  display: block;
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--bev-gold);
  margin-bottom: 0.5rem;
}

.bev-section-title {
  font-family: var(--font-display);
  font-size: 2.5rem;
  color: var(--bev-ink);
}

/* =========================================================
   📚 TARJETAS
========================================================= */
.bev-book-card-v2 {
  background: var(--pr-white);
  border: 1px solid var(--border-light);
  height: 100%;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
}

.bev-book-card-v2:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-md);
}

.bev-book-cover-v2 {
  position: relative;
  aspect-ratio: 2 / 3;
  overflow: hidden;
}

.bev-book-cover-v2 img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* INFO */
.bev-book-info-v2 {
  padding: 1.2rem;
  background: var(--bev-ink);
}

.bev-book-title {
  font-size: 1.05rem;
  color: var(--bev-cream);
  margin-bottom: 0.3rem;
}

.bev-book-author {
  font-size: 0.85rem;
  color: var(--bev-gold);
  font-style: italic;
}

.bev-book-price {
  color: var(--bev-cream);
  font-weight: bold;
  font-size: 1.1rem;
}

/* =========================================================
   🏷️ ETIQUETAS
========================================================= */
.bev-etiqueta {
  position: absolute;
  top: 12px;
  left: 0;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 5px 12px;
  z-index: 2;
  text-transform: uppercase;
}

.bev-etiqueta-nuevo {
  background: var(--bev-red);
  color: var(--pr-white);
}

.bev-etiqueta-destacado {
  background: var(--bev-gold);
  color: var(--bev-ink);
}

/* =========================================================
   🛒 BOTÓN
========================================================= */
.bev-btn-add-cart {
  background: transparent;
  border: 1px solid var(--bev-gold);
  color: var(--bev-gold);
  padding: 5px 10px;
  font-size: 0.8rem;
  transition: 0.3s;
}

.bev-btn-add-cart:hover {
  background: var(--bev-gold);
  color: var(--bev-ink);
}

</style>