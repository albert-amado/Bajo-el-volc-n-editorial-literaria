---
import libros from "../data/libros.json";

const etiquetasMap: Record<string, string> = {
  nuevo: "Nuevo",
  destacado: "Destacado",
  preventa: "En preventa",
  descuento: "Oferta",
};
---

<section class="py-5">
  <div class="bev-container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light">Colección de Bajo el Volcán</span>
      <h2 class="bev-section-title">Nuestras Novelas</h2>
    </div>

    <div class="bev-carousel-wrapper">

      <button class="bev-carousel-ctrl" id="btnPrev" type="button" aria-label="Anterior">
        <i class="bi bi-chevron-left"></i>
      </button>

      <div class="bev-carousel-viewport">
        <div class="bev-carousel-track" id="carouselTrack">
          {libros.map((libro) => (
            <div class="bev-carousel-slide">

              <div
                class="bev-book-cover-v2 js-card-modal"
                data-id={libro.id}
                style="cursor:pointer;"
              >
                <img src={libro.imagen} alt={libro.titulo} loading="lazy" />
                {libro.etiqueta && (
                  <span class={`bev-etiqueta bev-etiqueta-${libro.etiqueta.toLowerCase()}`}>
                    {etiquetasMap[libro.etiqueta] || libro.etiqueta}
                  </span>
                )}
              </div>

              <div class="bev-book-info-v2">
                <span class="bev-book-genre">{libro.genero}</span>
                <h5 class="bev-book-title">{libro.titulo}</h5>
                <p class="bev-book-author">{libro.autor}</p>

                <div class="bev-book-footer">
                  <span class="bev-book-price">
                    ${libro.precio.toLocaleString("es-CO")}
                  </span>
                  <div class="d-flex gap-2 flex-wrap">
                    <button
                      class="btn btn-sm bev-btn-outline js-btn-modal"
                      data-id={libro.id}
                    >
                      <i class="bi bi-plus-circle"></i> Conoce más
                    </button>
                    <button
                      class="btn bev-btn-add-cart js-btn-carrito"
                      data-id={libro.id}
                      data-titulo={libro.titulo}
                      data-precio={libro.precio}
                    >
                      <i class="bi bi-bag-plus fs-5"></i> Comprar ahora
                    </button>
                  </div>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

      <button class="bev-carousel-ctrl" id="btnNext" type="button" aria-label="Siguiente">
        <i class="bi bi-chevron-right"></i>
      </button>

    </div>
  </div>
</section>

<script>
  import { abrirModal } from "../js/modal.js";
  import { agregarAlCarrito } from "../js/carrito.js";

  document.addEventListener("astro:page-load", () => {
    const track = document.getElementById("carouselTrack") as HTMLElement;
    const slides = track?.querySelectorAll<HTMLElement>(".bev-carousel-slide");
    if (!slides || !track) return;

    // Número de slides visibles según el ancho de pantalla
    function getVisible(): number {
      if (window.innerWidth < 640) return 1;
      if (window.innerWidth < 992) return 2;
      return 3;
    }

    let current = 0;

    function mover(dir: number) {
      const VISIBLE = getVisible();
      const max = Math.max(0, slides.length - VISIBLE);
      current += dir;
      if (current > max) current = 0;
      if (current < 0) current = max;
      const slideWidth = slides[0].offsetWidth + 32; // gap: 2rem = 32px
      track.style.transform = `translateX(-${current * slideWidth}px)`;
    }

    document.getElementById("btnPrev")?.addEventListener("click", () => mover(-1));
    document.getElementById("btnNext")?.addEventListener("click", () => mover(1));

    // Resetear posición al cambiar tamaño de pantalla
    window.addEventListener("resize", () => {
      current = 0;
      track.style.transform = "translateX(0)";
    });

    // Modal
    document.querySelectorAll(".js-card-modal, .js-btn-modal").forEach((trigger) => {
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = trigger.getAttribute("data-id");
        if (id) abrirModal(parseInt(id));
      });
    });

    // Carrito
    document.querySelectorAll(".js-btn-carrito").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.getAttribute("data-id");
        const titulo = btn.getAttribute("data-titulo");
        const precio = parseFloat(btn.getAttribute("data-precio") || "0");
        if (id && titulo) agregarAlCarrito(id, titulo, precio);
      });
    });
  });
</script>

<style>
  .bev-carousel-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .bev-carousel-viewport {
    overflow: hidden;
    width: 100%;
  }

  .bev-carousel-track {
    display: flex;
    gap: 2rem;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Desktop: 3 slides */
  .bev-carousel-slide {
    flex: 0 0 calc(33.333% - 1.4rem);
    min-width: calc(33.333% - 1.4rem);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Tablet: 2 slides */
  @media (max-width: 991px) {
    .bev-carousel-slide {
      flex: 0 0 calc(50% - 1rem);
      min-width: calc(50% - 1rem);
    }
  }

  /* Móvil: 1 slide */
  @media (max-width: 639px) {
    .bev-carousel-slide {
      flex: 0 0 100%;
      min-width: 100%;
    }

    .bev-carousel-wrapper {
      gap: 0.5rem;
    }
  }

  /* ── Flechas ── */
  .bev-carousel-ctrl {
    background: none;
    border: none;
    color: var(--pr-gray-400);
    font-size: 2.8rem;
    line-height: 1;
    padding: 0.3rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.2s ease;
  }

  .bev-carousel-ctrl:hover {
    color: var(--pr-gray-900);
    transform: scale(1.2);
  }

  @media (max-width: 639px) {
    .bev-carousel-ctrl {
      font-size: 1.8rem;
    }
  }

  /* ── Portada ── */
  .bev-book-cover-v2 {
    position: relative;
  }

  .bev-book-cover-v2 img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Info ── */
  .bev-book-info-v2 {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.2rem 1.1rem;
    background: var(--pr-gray-400);
    border-left: 2px solid var(--pr-gray-400);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .bev-book-genre {
    font-size: 0.9rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--pr-gray-900);
    margin: 0;
  }

  .bev-book-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.5vw, 2.8rem);
    font-weight: 700;
    color: var(--pr-gray-900);
    margin: 0;
    line-height: 1.2;
  }

  .bev-book-author {
    font-size: 1.1rem;
    color: var(--pr-gray-900);
    font-style: italic;
    margin: 0;
  }

  .bev-book-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border-light);
  }

  .bev-book-price {
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--pr-gray-1200);
  }

  /* ── Botón carrito ── */
  .bev-btn-add-cart {
    background: var(--pr-gray-900);
    border: none;
    color: var(--pr-white);
    padding: 8px 14px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.3s, color 0.3s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .bev-btn-add-cart:hover {
    background: var(--pr-gray-400);
    color: var(--pr-gray-900);
  }
</style>