---
---
<!-- LIBROS DESTACADOS -->
<section class="py-5 bev-section-light">
    <!-- Título -->
    <div class="text-center mb-5">
      <span class="bev-section-tag">Coleccion de Bajo el Volcán</span>
      <h6 class="bev-section-title">Nuestras Novelas</h6>
    </div>

      <!-- Columna derecha: carrusel -->
      <div class="col-12 col-lg-10">
        <div
          id="librosCarousel"
          class="carousel slide"
          data-bs-ride="carousel"
          data-bs-interval="4000"
        >
          <div class="carousel-inner" id="librosCarouselInner">
            <!-- Generado por main.js desde libros.json -->
          </div>
          <button
            class="carousel-control-prev bev-carousel-ctrl"
            type="button"
            data-bs-target="#librosCarousel"
            data-bs-slide="prev"
          >
            <i class="bi bi-chevron-left"></i>
          </button>
          <button
            class="carousel-control-next bev-carousel-ctrl"
            type="button"
            data-bs-target="#librosCarousel"
            data-bs-slide="next"
          >
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    </div><!-- /.row -->
</section>