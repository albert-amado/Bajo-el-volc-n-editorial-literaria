---
// --- ESTA ES LA SECCIÓN DE FRONTMATTER (Lógica de servidor) ---
import autores from '../data/autores.json';

const autoresDestacados = autores.slice(0, 6);

const getInitials = (nombre: string) => {
  return nombre
    .split(' ')
    .map(n => n[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
};
---

<section class="py-5 bev-section-dark">
  <div class="container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light">Voces Bajo el Volcán</span>
      <h2 class="bev-section-title text-white">Nuestros autores</h2>
    </div>

    <div class="row g-4 justify-content-center">
      {autoresDestacados.map((autor) => (
        <div class="col-6 col-md-4 col-lg-2 text-center">
          
          {/* 1. ENLACE EN LA IMAGEN */}
          <a href={`/autores/${autor.id}`} class="bev-author-link">
            <div class="bev-author-avatar-wrap mx-auto">
              <img 
                src={autor.foto} 
                alt={autor.nombre} 
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="bev-avatar-fallback" style="display:none">
                {getInitials(autor.nombre)}
              </div>
            </div>
          </a>

          <p class="bev-author-name mt-3">{autor.nombre}</p>
          <p class="bev-author-country text-muted small">{autor.nacionalidad}</p>
          
          <div class="mt-3">
            <a href={`/autores/${autor.id}`} class="btn btn-sm bev-btn-outline-light">
              Ver sus obras
            </a>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<style is:global>
  /* Estilo para que la imagen se sienta clickeable */
  .bev-author-link {
    display: block;
    transition: transform 0.3s ease;
    text-decoration: none;
  }
  .bev-author-link:hover {
    transform: scale(1.08);
  }

  /* Aseguramos que los avatars mantengan su forma */
  .bev-author-avatar-wrap {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--pr-gray-400);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(255,255,255,0.1);
  }

  .bev-author-avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bev-avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pr-white);
    font-weight: bold;
    font-size: 1.5rem;
    background: linear-gradient(45deg, var(--pr-gray-900), #333);
  }

  .bev-author-name {
    color: var(--pr-white);
    font-weight: 600;
    margin-bottom: 2px;
  }

  .bev-author-country {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .bev-author-bio {
    color: var(--pr-gray-400);
    font-size: 0.85rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 8px;
  }

  .bev-author-avatar-wrap {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 2px solid var(--pr-gray-400);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--pr-gray-900);
    transition: border-color 0.2s, transform 0.2s;
  }

  .bev-author-avatar-wrap:hover {
    border-color: var(--pr-gray-200);
    transform: translateY(-4px);
  }

  .bev-author-avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .bev-avatar-fallback {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--pr-gray-400);
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-author-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--pr-white);
    margin-bottom: 0.1rem;
  }

  .bev-author-country {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pr-gray-400);
    margin-bottom: 0.5rem;
  }

  .bev-author-bio {
    font-size: 0.78rem;
    color: var(--pr-gray-400);
    line-height: 1.5;
    margin: 0;
  }
</style>