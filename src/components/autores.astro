---
import autores from "../data/autores.json";

const autoresDestacados = autores.slice(0, 6);

const getInitials = (nombre: string) => {
  return nombre
    .split(" ")
    .map((n) => n[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();
};
---

<section class="py-5 bev-section-dark">
  <div class="container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light">Voces Bajo el Volcán</span>
      <h2 class="bev-section-title">Nuestros autores</h2>
    </div>

    <div data-aos="fade-up">
      <div class="row g-4 justify-content-center">
        {
          autoresDestacados.map((autor) => (
            <div class="col-6 col-md-4 col-lg-2 text-center">
              <a href={`/autores/${autor.id}`} class="bev-author-link">
                <div class="bev-author-avatar mx-auto">
                  <img
                    src={autor.foto}
                    alt={autor.nombre}
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                  <div class="bev-avatar-fallback" style="display:none">
                    {getInitials(autor.nombre)}
                  </div>
                </div>
              </a>

              <p class="bev-author-name mt-3">{autor.nombre}</p>
              <p class="bev-author-country">{autor.nacionalidad}</p>

              <div class="mt-3">
                <a href={`/autores/${autor.id}`} class="btn bev-btn-autor">
                  <i class="bi bi-plus-circle me-2" />
                  Ver sus obras
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  .bev-author-link {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
    width: fit-content;
    margin: 0 auto;
  }

  .bev-author-link:hover {
    transform: scale(1.08);
  }

  .bev-author-avatar {
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--pr-gray-900);
    border: 2px solid var(--pr-gray-400);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .bev-author-avatar:hover {
    border-color: var(--pr-gray-200);
    transform: translateY(-4px);
  }

  .bev-author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .bev-avatar-fallback {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--pr-gray-400);
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-author-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--pr-gray-900);
    margin-bottom: 0.2rem;
  }

  .bev-author-country {
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pr-gray-400);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .bev-btn-autor {
    background: transparent;
    border: 1px solid var(--pr-gray-400);
    color: var(--pr-gray-900);
    font-size: 0.8rem;
    padding: 0.45rem 1.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .bev-btn-autor:hover {
    background: var(--pr-gray-400);
    color: var(--pr-gray-900);
    border-color: var(--pr-gray-400);
  }
</style>
