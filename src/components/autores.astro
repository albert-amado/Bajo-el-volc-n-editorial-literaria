---
import autores from "../data/autores.json";

const autoresDestacados = autores.slice(0, 6);

const getInitials = (nombre: string) => {
  return nombre
    .split(" ")
    .map((n) => n[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();
};
---

<section class="py-5 bev-section bev-section-dark">
  <div class="container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light">Voces Bajo el Volcán</span>
      <h2 class="bev-section-title">Nuestros autores</h2>

      <div class="bev-section-line"></div>
    </div>

    <div data-aos="fade-up">
      <div class="row g-4 justify-content-center">
        {
          autoresDestacados.map((autor) => (
            <div class="col-6 col-md-4 col-lg-2 text-center">
              <a href={`/autores/${autor.id}`} class="bev-author-link">
                <div class="bev-author-avatar mx-auto">
                  <img
                    src={
                      autor.foto.startsWith("/") ? autor.foto : `/${autor.foto}`
                    }
                    alt={autor.nombre}
                    loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                  <div class="bev-avatar-fallback" style="display:none">
                    {getInitials(autor.nombre)}
                  </div>
                </div>
              </a>

              <p class="bev-author-name mt-3">{autor.nombre}</p>
              <p class="bev-author-country">{autor.nacionalidad}</p>

              <div class="mt-3">
                <a href={`/autores/${autor.id}`} class="btn bev-btn-autor">
                  <i class="bi bi-plus-circle me-1" /> Ver sus obras
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
<style>
  .bev-author-link {
    display: block;
    text-decoration: none;
    width: fit-content;
    margin: 0 auto;
    transition: transform 0.3s ease;
  }

  .bev-author-link:hover {
    transform: scale(1.05);
  }

  .bev-author-avatar {
    width: clamp(90px, 14vw, 200px);
    height: clamp(90px, 14vw, 200px);
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--pr-gray-900);
    border: 2px solid var(--pr-gray-400);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .bev-author-avatar:hover {
    border-color: var(--pr-gray-200);
    transform: translateY(-4px);
  }

  .bev-author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .bev-avatar-fallback {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--pr-gray-400);
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-author-name {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.5vw, 1.3rem);
    font-weight: 700;
    color: var(--pr-gray-900);
    margin-bottom: 0.2rem;
  }

  .bev-author-country {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pr-gray-400);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .bev-btn-autor {
    background: transparent;
    border: 1px solid var(--pr-gray-1500);
    color: var(--pr-gray-900);
    font-size: 0.78rem;
    padding: 0.4rem 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .bev-btn-autor:hover {
    background: var(--pr-gray-400);
    color: var(--pr-gray-900);
    border-color: var(--pr-gray-400);
  }
  .bev-section-dark {
    background: var(--pr-gray-400);
    color: var(--pr-gray-900);
  }

  .bev-section-tag-light {
    text-align: left;
    display: block;
  }

  .bev-section-title {
    text-align: left;
  }

  .bev-section-line {
    height: 3px;
    width: 800px;
    background: var(--pr-gray-1500);
    margin: 1rem 0 2.5rem 0;
    border-radius: 5px;
  }

  @media (max-width: 576px) {
    .bev-section-line {
      width: 140px;
    }

    .bev-author-avatar {
      width: 120px;
      height: 120px;
    }

    .bev-author-name {
      font-size: 0.95rem;
    }

    .bev-btn-autor {
      font-size: 0.72rem;
      padding: 0.38rem 0.8rem;
    }
  }

  @media (max-width: 420px) {
    .row.g-4.justify-content-center > .col-6 {
      width: 100%;
    }

    .bev-author-country {
      font-size: 0.7rem;
    }
  }
  
</style>
