---
---
<section class="py-5 bev-section-dark">
  <div class="container">
    <div class="text-center mb-5">
      <span class="bev-section-tag-light">Voces Bajo el Volcán</span>
      <h2 class="bev-section-title text-white">Nuestros autores</h2>
    </div>
    <div class="row g-4 justify-content-center" id="autoresGrid"></div>
    <div class="text-center mt-5">
      <a href="pages/autores.html" class="btn bev-btn-outline-light"
        >Ver todos los autores</a
      >
    </div>
  </div>
</section>

<style is:global>
  .bev-author-avatar-wrap {
  width: 200px;
  height: 200px;
  border-radius: 50%;
  border: 2px solid var(--bev-gold);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bev-charcoal);
  transition: border-color 0.2s, transform 0.2s;
}

.bev-author-avatar-wrap:hover {
  border-color: var(--bev-gold-lt);
  transform: translateY(-4px);
}

.bev-author-avatar-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
}

.bev-avatar-fallback {
  font-family: var(--font-display);
  font-size: 1.4rem;
  color: var(--bev-gold);
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bev-author-name {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--bev-cream);
  margin-bottom: 0.1rem;
}

.bev-author-country {
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--bev-gold);
  margin-bottom: 0.5rem;
}

.bev-author-bio {
  font-size: 0.78rem;
  color: var(--bev-ash);
  line-height: 1.5;
  margin: 0;
}

</style>
