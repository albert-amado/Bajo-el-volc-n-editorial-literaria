---
// 1. Importamos los datos directamente desde tu carpeta data
import libros from "../data/libros.json";

// 2. Tomamos solo los primeros 9 libros para el Hero, igual que en tu JS
const slides = libros.slice(0, 9);
---

<section class="py-4">
  <div class="bev-container">
    <div
      id="heroCarousel"
      class="carousel slide carousel-fade bev-carousel-custom"
      data-bs-ride="carousel"
      data-bs-interval="5000"
    >
      <div class="carousel-indicators">
        {
          slides.map((_, i) => (
            <button
              type="button"
              data-bs-target="#heroCarousel"
              data-bs-slide-to={i}
              class={i === 0 ? "active" : ""}
              aria-current={i === 0 ? "true" : "false"}
              aria-label={`Slide ${i + 1}`}
            />
          ))
        }
      </div>

      <div class="carousel-inner">
        {
          slides.map((libro, i) => (
            <div
              class={`carousel-item bev-slide ${i === 0 ? "active" : ""}`}
              style={`background-image: url('${libro.imagen_hero || libro.imagen}');`}
            >
              <div class="bev-slide-overlay" />
              <div class="container h-100">
                <div class="row h-100 align-items-center">
                  <div class="col-lg-6 bev-slide-content">
                    {libro.etiqueta === "nuevo" && (
                      <span class="bev-hero-badge bev-etiqueta-nuevo">
                        Nuevo
                      </span>
                    )}
                    {libro.etiqueta === "preventa" && (
                      <span class="bev-hero-badge bev-etiqueta-preventa">
                        Próximo lanzamiento
                      </span>
                    )}

                    <span class="bev-eyebrow">{libro.genero}</span>
                    <h1 class="bev-slide-title">{libro.titulo}</h1>
                    <p class="bev-slide-author">{libro.autor}</p>

                    <p class="bev-slide-desc">
                      {libro.descripcion
                        ? libro.descripcion.substring(0, 120) + "..."
                        : ""}
                    </p>

                    <div class="d-flex gap-3 flex-wrap mt-4">
                      <button
                        class="btn bev-btn-gold btn-add-cart"
                        data-id={libro.id}
                        data-titulo={libro.titulo}
                      >
                        Agregar al carrito
                      </button>
                      <a href="/catalogo" class="btn bev-btn-outline-light">
                        Ver catálogo
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <button
        class="carousel-control-prev"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="prev"
      >
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button
        class="carousel-control-next"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="next"
      >
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
  </div>
</section>
<style is:global>
  .bev-container {
    width: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .bev-carousel-custom {
    width: 100%;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .bev-slide {
    height: 45vh;
    min-height: 350px;
    position: relative;

    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--carousel-bg);

    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .bev-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.6) 40%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }
  .bev-slide-content {
    position: relative;
    z-index: 2;

    width: 100%;
    padding-left: 2rem;

    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  /* Categoría */
  .bev-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--pr-white);
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  /* Título */
  .bev-slide-title {
    font-family: "Lato", sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--pr-white);
    margin-bottom: 0.5rem;
  }

  /* Autor */
  .bev-slide-author {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--pr-white);
    opacity: 0.85;
    margin-bottom: 1rem;
  }

  .bev-slide-desc {
    font-size: 0.95rem;
    color: var(--pr-white);
    opacity: 0.8;
    max-width: 500px;
    line-height: 1.5;
  }

  .bev-slide-actions {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
  }

  .bev-btn {
    position: relative;
    color: var(--pr-white);
    border: 1px solid rgba(255, 255, 255, 0.6);
    padding: 0.5rem 1.4rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  /* Línea animada */
  .bev-btn::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 50%;
    width: 0%;
    height: 1px;
    background: var(--pr-white);
    transform: translateX(-50%);
    transition: width 0.3s ease;
  }

  .bev-btn:hover::after {
    width: 70%;
  }

  .bev-btn:hover {
    border-color: var(--pr-white);
  }

  @media (max-width: 768px) {
    .bev-slide {
      height: 45vh;
    }

    .bev-slide-content {
      padding-left: 1rem;
    }

    .bev-slide-title {
      font-size: 1.8rem;
    }
  }
</style>
