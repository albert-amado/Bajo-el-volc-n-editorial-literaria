---
import libros from "../data/libros.json";

const slides = libros.slice(0, 9);
---

<section class="pt-0 pb-4">
  <div class="container-fluid px-0">
    <div
      id="heroCarousel"
      class="carousel slide carousel-fade bev-carousel-custom"
      data-bs-ride="carousel"
      data-bs-interval="5000"
    >
      <div class="carousel-indicators">
        {slides.map((_, i) => (
          <button
            type="button"
            data-bs-target="#heroCarousel"
            data-bs-slide-to={i}
            class={i === 0 ? "active" : ""}
            aria-current={i === 0 ? "true" : "false"}
            aria-label={`Slide ${i + 1}`}
          />
        ))}
      </div>

      <div class="carousel-inner">
        {slides.map((libro, i) => (
          <div
            class={`carousel-item bev-slide ${i === 0 ? "active" : ""}`}
            style={`background-image: url('${libro.imagen_hero || libro.imagen}');`}
          >
            <div class="bev-slide-overlay"></div>
            <div class="container h-100">
              <div class="row h-100 align-items-center justify-content-center">
                <div class="col-11 col-lg-10 bev-slide-content text-center mx-auto">

                  {libro.etiqueta === "nuevo" && (
                    <span class="bev-hero-badge bev-etiqueta-nuevo">Nuevo</span>
                  )}
                  {libro.etiqueta === "preventa" && (
                    <span class="bev-hero-badge bev-etiqueta-preventa">Próximo lanzamiento</span>
                  )}

                  <span class="bev-eyebrow">{libro.genero}</span>
                  <h1 class="bev-slide-title">{libro.titulo}</h1>
                  <p class="bev-slide-author">{libro.autor}</p>
                  <p class="bev-slide-desc">
                    {libro.descripcion ? libro.descripcion.substring(0, 120) + "..." : ""}
                  </p>

                  <div class="d-flex gap-3 flex-wrap mt-4 justify-content-center">
                    <button
                      class="btn bev-btn-gold btn-add-cart"
                      data-id={libro.id}
                      data-titulo={libro.titulo}
                      data-precio={libro.precio}
                    >
                      Agregar al carrito
                    </button>
                  </div>

                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev" aria-label="Anterior">
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next" aria-label="Siguiente">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
  </div>
</section>

<script>
  import { agregarAlCarrito } from "../js/carrito.js";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll(".btn-add-cart").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id");
        const titulo = btn.getAttribute("data-titulo") || "";
        const precio = parseFloat(btn.getAttribute("data-precio") || "0");
        if (id) agregarAlCarrito(id, titulo, precio);
      });
    });
  });
</script>

<style is:global>
  .bev-carousel-custom {
    width: 100%;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .bev-slide {
    height: 70vh;
    min-height: 320px;
    position: relative;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--pr-gray-1000);
    display: flex;
    align-items: center;
  }

  .bev-slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.72) 50%,
      rgba(0, 0, 0, 0.85) 100%
    );
  }

  .bev-slide-content {
    position: relative;
    z-index: 2;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bev-eyebrow {
    font-size: 1rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--pr-white);
    opacity: 0.9;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .bev-slide-title {
    font-family: "Lato", sans-serif;
    font-size: clamp(2rem, 5vw, 5rem);
    font-weight: 800;
    color: var(--pr-white);
    margin-bottom: 0.4rem;
    line-height: 1.05;
  }

  .bev-slide-author {
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-style: italic;
    color: var(--pr-white);
    opacity: 0.95;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .bev-slide-desc {
    font-size: clamp(0.95rem, 1.5vw, 1.25rem);
    color: var(--pr-white);
    opacity: 0.9;
    max-width: 720px;
    line-height: 1.5;
    font-weight: 500;
  }

  /* Flechas */
  .bev-carousel-custom .carousel-control-prev,
  .bev-carousel-custom .carousel-control-next {
    width: 64px;
    height: 64px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 1;
    background-color: rgba(0, 0, 0, 0.35);
    border-radius: 50%;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-carousel-custom .carousel-control-prev:hover,
  .bev-carousel-custom .carousel-control-next:hover {
    background-color: rgba(0, 0, 0, 0.6);
    transform: translateY(-50%) scale(1.1);
  }

  .bev-carousel-custom .carousel-control-prev-icon,
  .bev-carousel-custom .carousel-control-next-icon {
    width: 36px;
    height: 36px;
    filter: brightness(0) invert(1);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .bev-slide {
      height: 55vh;
      min-height: 280px;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next {
      width: 44px;
      height: 44px;
    }

    .bev-carousel-custom .carousel-control-prev-icon,
    .bev-carousel-custom .carousel-control-next-icon {
      width: 26px;
      height: 26px;
    }

    .bev-eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.25em;
    }
  }

  @media (max-width: 480px) {
    .bev-slide {
      height: 60vh;
    }

    .bev-slide-desc {
      display: none; /* Ocultar descripción en móviles muy pequeños */
    }
  }
</style>