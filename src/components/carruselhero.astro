---
import libros from "../data/libros.json";

const slides = libros.slice(0, 9);
---

<section class="pt-0 pb-4 bev-hero-section">
  <div class="container-fluid px-0">
    <div
      id="heroCarousel"
      class="carousel slide carousel-fade bev-carousel-custom"
      data-bs-ride="carousel"
      data-bs-interval="5000"
    >
      <div class="carousel-indicators">
        {
          slides.map((_, i) => (
            <button
              type="button"
              data-bs-target="#heroCarousel"
              data-bs-slide-to={i}
              class={i === 0 ? "active" : ""}
              aria-current={i === 0 ? "true" : "false"}
              aria-label={`Slide ${i + 1}`}
            />
          ))
        }
      </div>

      <div class="carousel-inner">
        {
          slides.map((libro, i) => (
            <div
              class={`carousel-item bev-slide ${i === 0 ? "active" : ""}`}
              style={`background-image: url('${libro.imagen_hero || libro.imagen}');`}
            >
              <div class="bev-slide-overlay" />
              <div class="container h-100">
                <div class="row h-100 align-items-center justify-content-center">
                  <div class="col-11 col-lg-10 bev-slide-content text-center mx-auto">
                    {libro.etiqueta === "nuevo" && (
                      <span class="bev-hero-badge bev-etiqueta-nuevo">
                        Nuevo
                      </span>
                    )}
                    {libro.etiqueta === "preventa" && (
                      <span class="bev-hero-badge bev-etiqueta-preventa">
                        Próximo lanzamiento
                      </span>
                    )}

                    <span class="bev-eyebrow">{libro.genero}</span>
                    <h1 class="bev-slide-title">{libro.titulo}</h1>
                    <p class="bev-slide-author">{libro.autor}</p>
                    <p class="bev-slide-desc">{libro.frase || ""}</p>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <button
        class="carousel-control-prev bev-hero-nav bev-hero-nav--prev"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="prev"
        aria-label="Anterior"
      >
        <span class="bev-hero-arrow" aria-hidden="true"></span>
      </button>
      <button
        class="carousel-control-next bev-hero-nav bev-hero-nav--next"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="next"
        aria-label="Siguiente"
      >
        <span class="bev-hero-arrow" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</section>

<style is:global>
  .bev-hero-section .container-fluid {
    max-width: none;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  .bev-carousel-custom {
    width: min(100%, 1680px);
    margin: 0 auto;
    overflow: hidden;
    box-shadow: none;
    border-radius: 0;
  }

  .bev-slide {
    height: clamp(280px, 32vw, 500px);
    min-height: 280px;
    position: relative;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--pr-white);
    display: flex;
    align-items: center;
  }

  .bev-slide-overlay {
    display: none;
  }

  .bev-slide-content {
    display: none;
  }

  .bev-eyebrow {
    font-size: 1rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--pr-white);
    opacity: 0.9;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .bev-slide-title {
    font-family: "Lato", sans-serif;
    font-size: clamp(1.7rem, 4vw, 3.5rem);
    font-weight: 800;
    color: var(--pr-white);
    margin-bottom: 0.4rem;
    line-height: 1.1;
    text-wrap: balance;
  }

  .bev-slide-author {
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-style: italic;
    color: var(--pr-white);
    opacity: 0.95;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .bev-slide-desc {
    font-size: clamp(0.9rem, 1.4vw, 1.2rem);
    color: var(--pr-white);
    opacity: 0.95;
    max-width: 700px;
    width: 100%;
    line-height: 1.7;
    font-weight: 400;
    font-style: italic;
    text-align: center;
    margin: 0 auto;

    /* Mejora legibilidad sin overlay */
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
  }

  .bev-slide .container {
    max-width: 100%;
  }

  /* Flechas */
  .bev-carousel-custom .carousel-control-prev,
  .bev-carousel-custom .carousel-control-next {
    width: 56px;
    height: 56px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 1;
    background: transparent;
    border-radius: 0;
    transition: transform 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-carousel-custom .carousel-control-prev:hover,
  .bev-carousel-custom .carousel-control-next:hover {
    transform: translateY(-50%) scale(1.08);
  }

  .bev-hero-nav .bev-hero-arrow {
    display: block;
    width: 22px;
    height: 22px;
    border-top: 4px solid #ffffff;
    border-right: 4px solid #ffffff;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.28));
  }

  @media (min-width: 769px) {
    .bev-hero-nav .bev-hero-arrow {
      border-top-color: var(--pr-gray-900);
      border-right-color: var(--pr-gray-900);
      filter: drop-shadow(0 1px 2px rgba(255, 255, 255, 0.25));
    }
  }

  .bev-hero-nav--prev .bev-hero-arrow {
    transform: rotate(-135deg);
  }

  .bev-hero-nav--next .bev-hero-arrow {
    transform: rotate(45deg);
  }

  @media (min-width: 1200px) {
    .bev-carousel-custom {
      width: min(100%, 1760px);
    }

    .bev-slide {
      height: clamp(300px, 34vw, 540px);
      min-height: 300px;
    }

    .bev-carousel-custom .carousel-control-prev {
      left: 1.5rem;
    }

    .bev-carousel-custom .carousel-control-next {
      right: 1.5rem;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 26px;
      height: 26px;
      border-top-width: 4px;
      border-right-width: 4px;
    }
  }

  @media (max-width: 768px) {
    .bev-slide {
      height: clamp(120px, 28vw, 170px);
      min-height: 120px;
      background-position: center center;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next {
      width: 44px;
      height: 44px;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next,
    .carousel-indicators {
      opacity: 0.95;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 18px;
      height: 18px;
      border-top-width: 3px;
      border-right-width: 3px;
    }

    .bev-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
    }

  }

  @media (max-width: 480px) {
    .bev-slide {
      height: clamp(110px, 34vw, 150px);
      min-height: 110px;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next {
      width: 38px;
      height: 38px;
      top: auto;
      bottom: 0.75rem;
      transform: none;
    }

    .bev-carousel-custom .carousel-control-prev:hover,
    .bev-carousel-custom .carousel-control-next:hover {
      transform: scale(1.04);
    }

    .bev-carousel-custom .carousel-control-prev {
      left: 0.75rem;
    }

    .bev-carousel-custom .carousel-control-next {
      right: 0.75rem;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 15px;
      height: 15px;
      border-top-width: 2.5px;
      border-right-width: 2.5px;
    }

    .carousel-indicators {
      margin-bottom: 0.5rem;
    }
  }

  @media (max-width: 420px) {
    .bev-carousel-custom {
      width: calc(100% - 1rem);
    }
  }
</style>
