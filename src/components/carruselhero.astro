---
import libros from "../data/libros.json";

const slides = libros.slice(0, 9);
---

<section class="pt-0 pb-4">
  <div class="container-fluid px-0">
    <div
      id="heroCarousel"
      class="carousel slide carousel-fade bev-carousel-custom"
      data-bs-ride="carousel"
      data-bs-interval="5000"
    >
      <div class="carousel-indicators">
        {
          slides.map((_, i) => (
            <button
              type="button"
              data-bs-target="#heroCarousel"
              data-bs-slide-to={i}
              class={i === 0 ? "active" : ""}
              aria-current={i === 0 ? "true" : "false"}
              aria-label={`Slide ${i + 1}`}
            />
          ))
        }
      </div>

      <div class="carousel-inner">
        {
          slides.map((libro, i) => (
            <div
              class={`carousel-item bev-slide ${i === 0 ? "active" : ""}`}
              style={`background-image: url('${libro.imagen_hero || libro.imagen}');`}
            >
              <div class="bev-slide__overlay"></div>
              {
                libro.frase && (
                  <p class="bev-slide__phrase">{libro.frase}</p>
                )
              }
            </div>
          ))
        }
      </div>

      <button
        class="carousel-control-prev bev-hero-nav bev-hero-nav--prev"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="prev"
        aria-label="Anterior"
      >
        <span class="bev-hero-arrow" aria-hidden="true"></span>
      </button>
      <button
        class="carousel-control-next bev-hero-nav bev-hero-nav--next"
        type="button"
        data-bs-target="#heroCarousel"
        data-bs-slide="next"
        aria-label="Siguiente"
      >
        <span class="bev-hero-arrow" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</section>

<style is:global>
  .bev-carousel-custom {
    width: min(100%, 1680px);
    margin: 0 auto;
    overflow: hidden;
    box-shadow: none;
    border-radius: 0;
  }

  .bev-slide {
    height: clamp(280px, 32vw, 500px);
    min-height: 280px;
    position: relative;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--pr-white);
  }

  .bev-slide__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.48) 0%,
      rgba(0, 0, 0, 0.36) 40%,
      rgba(0, 0, 0, 0.52) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .bev-slide__phrase {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(86%, 980px);
    margin: 0;
    z-index: 2;
    text-align: center;
    font-style: italic;
    color: var(--pr-whuite, var(--pr-white));
    font-size: clamp(0.95rem, 1.6vw, 1.5rem);
    line-height: 1.45;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
    padding: 0 0.5rem;
  }

  /* Flechas */
  .bev-carousel-custom .carousel-control-prev,
  .bev-carousel-custom .carousel-control-next {
    width: 56px;
    height: 56px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 1;
    background: transparent;
    border-radius: 0;
    transition: transform 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bev-carousel-custom .carousel-control-prev:hover,
  .bev-carousel-custom .carousel-control-next:hover {
    transform: translateY(-50%) scale(1.08);
  }

  .bev-hero-nav .bev-hero-arrow {
    display: block;
    width: 22px;
    height: 22px;
    border-top: 4px solid var(--pr-white);
    border-right: 4px solid var(--pr-white);
    filter: drop-shadow(0 2px 4px var(--pr-glass-dark-28));
  }

  @media (min-width: 769px) {
    .bev-hero-nav .bev-hero-arrow {
      border-top-color: var(--pr-gray-900);
      border-right-color: var(--pr-gray-900);
      filter: drop-shadow(0 1px 2px var(--pr-glass-light-25));
    }
  }

  .bev-hero-nav--prev .bev-hero-arrow {
    transform: rotate(-135deg);
  }

  .bev-hero-nav--next .bev-hero-arrow {
    transform: rotate(45deg);
  }

  @media (min-width: 1200px) {
    .bev-carousel-custom {
      width: min(100%, 1760px);
    }

    .bev-slide {
      height: clamp(300px, 34vw, 540px);
      min-height: 300px;
    }

    .bev-carousel-custom .carousel-control-prev {
      left: 1.5rem;
    }

    .bev-carousel-custom .carousel-control-next {
      right: 1.5rem;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 26px;
      height: 26px;
      border-top-width: 4px;
      border-right-width: 4px;
    }
  }

  @media (max-width: 768px) {
    .bev-slide {
      height: clamp(180px, 38vw, 260px);
      min-height: 180px;
      background-position: center center;
    }

    .bev-slide__phrase {
      width: min(90%, 760px);
      font-size: clamp(0.78rem, 2.6vw, 1.02rem);
      line-height: 1.36;
      -webkit-line-clamp: 4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next {
      width: 44px;
      height: 44px;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next,
    .bev-carousel-custom .carousel-indicators {
      opacity: 0.95;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 18px;
      height: 18px;
      border-top-width: 3px;
      border-right-width: 3px;
    }

  }

  @media (max-width: 480px) {
    .bev-slide {
      height: clamp(210px, 58vw, 300px);
      min-height: 210px;
    }

    .bev-slide__phrase {
      width: 88%;
      top: 46%;
      font-size: clamp(0.74rem, 3.5vw, 0.92rem);
      line-height: 1.33;
      -webkit-line-clamp: 5;
    }

    .bev-carousel-custom .carousel-control-prev,
    .bev-carousel-custom .carousel-control-next {
      width: 38px;
      height: 38px;
      top: auto;
      bottom: 0.75rem;
      transform: none;
    }

    .bev-carousel-custom .carousel-control-prev:hover,
    .bev-carousel-custom .carousel-control-next:hover {
      transform: scale(1.04);
    }

    .bev-carousel-custom .carousel-control-prev {
      left: 0.75rem;
    }

    .bev-carousel-custom .carousel-control-next {
      right: 0.75rem;
    }

    .bev-hero-nav .bev-hero-arrow {
      width: 15px;
      height: 15px;
      border-top-width: 2.5px;
      border-right-width: 2.5px;
    }

    .bev-carousel-custom .carousel-indicators {
      margin-bottom: 0.5rem;
    }
  }

  @media (max-width: 360px) {
    .bev-slide {
      height: clamp(200px, 62vw, 250px);
      min-height: 200px;
    }

    .bev-slide__phrase {
      width: 90%;
      top: 45%;
      font-size: clamp(0.68rem, 3.8vw, 0.84rem);
      line-height: 1.3;
      -webkit-line-clamp: 5;
    }
  }

  @media (max-width: 420px) {
    .bev-carousel-custom {
      width: calc(100% - 1rem);
    }
  }
</style>
