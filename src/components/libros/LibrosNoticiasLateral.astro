---
import {
  formatNewsDate,
  getCategoriaColorClass,
  noticiasPreparadas,
} from "../../utils/noticias.js";
---

<div class="bev-noticias-lateral">
  <p class="bev-categorias-titulo">NOTICIAS</p>
  <div class="d-flex flex-column gap-3">
    {
      noticiasPreparadas.map((noticia) => (
        <a href={`/noticias/${noticia.slug}`} class="text-decoration-none">
          <div class="bev-noticia-card-mini">
            <div class="bev-noticia-img-mini">
              {noticia.imagen ? (
                <img src={noticia.imagen} alt={noticia.titulo} loading="lazy" />
              ) : (
                <div class="bev-img-placeholder-mini">
                  <i class="bi bi-newspaper" />
                </div>
              )}
              <span class={`bev-categoria-badge-mini ${getCategoriaColorClass(noticia.categoriaKey)}`}>
                {noticia.categoriaLabel}
              </span>
            </div>
            <div class="bev-noticia-body-mini p-2">
              <p class="bev-noticia-fecha-mini mb-1">
                <i class="bi bi-calendar3 me-1" />
                {formatNewsDate(noticia.fecha)}
              </p>
              <p class="bev-noticia-titulo-mini mb-1">{noticia.titulo}</p>
              <p class="bev-noticia-resumen-mini">{noticia.resumen}</p>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>

<style>
  .bev-categorias-titulo {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: 0.4em;
    color: var(--pr-white);
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .bev-noticias-lateral {
    padding-top: 0;
    margin-right: -1.5rem;
  }

  .bev-noticia-card-mini {
    background-color: transparent;
    border: none;
    border-radius: 0;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .bev-noticia-card-mini:hover {
    transform: translateY(-2px);
  }

  .bev-noticia-img-mini {
    position: relative;
    height: 120px;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.08);
  }

  .bev-noticia-img-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .bev-noticia-card-mini:hover .bev-noticia-img-mini img {
    transform: scale(1.05);
  }

  .bev-img-placeholder-mini {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .bev-categoria-badge-mini {
    position: absolute;
    top: 8px;
    left: 8px;
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .bev-cat-evento     { background-color: var(--pr-gray-400); color: var(--pr-gray-900); }
  .bev-cat-lanzamiento{ background-color: var(--pr-gray-900); color: var(--pr-white); }
  .bev-cat-convocatoria{ background-color: var(--pr-gray-100); color: var(--pr-gray-900); }
  .bev-cat-entrevista { background-color: var(--pr-gray-700); color: var(--pr-white); }
  .bev-cat-premio     { background-color: var(--pr-gray-200); color: var(--pr-gray-900); }

  .bev-noticia-fecha-mini {
    font-size: 0.7rem;
    color: var(--pr-gray-200);
  }

  .bev-noticia-titulo-mini {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--pr-white);
    line-height: 1.3;
    margin: 0;
  }

  .bev-noticia-resumen-mini {
    font-size: 0.75rem;
    color: var(--pr-gray-200);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  @media (max-width: 991px) {
    .bev-noticias-lateral {
      margin-right: 0;
    }
  }

  @media (max-width: 575px) {
    .bev-categorias-titulo {
      font-size: 1rem;
      letter-spacing: 0.25em;
    }

    .bev-noticia-img-mini {
      height: 104px;
    }

    .bev-noticia-titulo-mini {
      font-size: 0.8rem;
    }

    .bev-noticia-resumen-mini {
      font-size: 0.72rem;
    }
  }
</style>