---

<div class="bev-contact-form mb-4">
  <h5 class="fw-bold mb-3">Déjanos tu mensaje</h5>
  <div class="d-flex flex-column gap-3">
    <input type="text" id="inputNombre" class="bev-form-input" placeholder="Nombre" />
    <input type="email" id="inputCorreo" class="bev-form-input" placeholder="Correo electrónico" />
    <input type="text" id="inputAsunto" class="bev-form-input" placeholder="Asunto" />
    <textarea id="inputMensaje" class="bev-form-input" rows="3" placeholder="Tu mensaje..."></textarea>

    <a
      href="mailto:bajoelvolcane@gmail.com"
      id="btnEnviarLibros"
      class="btn bev-btn-submit w-100 d-flex align-items-center justify-content-center"
    >
      <i class="bi bi-send me-2"></i>
      Enviar mensaje
    </a>

    <div class="text-center mt-3">
      <small class="text-muted">o contáctanos directamente por</small><br />
     <a 
        href="https://wa.me/573144559506"
        target="_blank"
        rel="noopener noreferrer"
        class="bev-contact-value d-inline-flex align-items-center gap-1"
      >
        <i class="bi bi-whatsapp"></i>
        +57 314 455 9506
      </a>
    </div>

    <div id="formMensajeLibros" class="bev-form-feedback d-none"></div>
  </div>
</div>

<style>
  .bev-contact-form {
    background-color: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
  }

  .bev-contact-form.mb-4 {
    margin-right: -1.5rem;
  }

  .bev-contact-form h5 {
    color: var(--pr-white);
    font-family: var(--font-body);
  }

  .bev-form-input {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    color: var(--pr-white);
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s;
  }

  .bev-form-input::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .bev-form-input:focus {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .bev-btn-submit {
    background-color: var(--pr-black);
    color: var(--pr-white);
    border: none;
    padding: 0.8rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .bev-btn-submit:hover {
    opacity: 0.85;
  }

  .bev-form-feedback {
    padding: 0.75rem;
    border-radius: 8px;
    font-size: 0.85rem;
    text-align: center;
  }

  .bev-feedback-ok {
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--pr-white);
  }

  .bev-feedback-error {
    background-color: var(--status-error-bg);
    border: 1px solid var(--status-error-border);
    color: var(--status-error-text);
  }

  .bev-contact-value {
    color: var(--pr-white);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .bev-contact-value:hover {
    color: var(--pr-gray-200);
  }

  @media (max-width: 639px) {
    .bev-contact-form {
      padding: 0;
    }

    .bev-contact-form.mb-4 {
      margin-right: 0;
    }

    .bev-contact-form h5 {
      font-size: 1rem;
    }

    .bev-contact-value {
      word-break: break-word;
    }
  }
</style>