<div class="bev-topbar">
  <div class="container-fluid d-flex justify-content-between align-items-center">

    <div class="d-flex gap-3">
      <!-- Teléfono ahora es clicable (tel:) -->
      <a href="tel:+573144559506" class="bev-topbar-info">
        <i class="bi bi-telephone"></i> 314-455-9506
      </a>

      <!-- Email sin cambios (sigue siendo solo texto) -->
      <span class="bev-topbar-info">
        <i class="bi bi-envelope"></i> bajoelvolcane@gmail.com
      </span>

      <!-- Nuevo campo: "Déjanos tu mensaje" con icono de mensaje y enlace a /contacto -->
      <a href="/contacto" class="bev-topbar-info">
        <i class="bi bi-chat"></i> Déjanos tu mensaje
      </a>
    </div>

    <span class="bev-topbar-marca">Bajo el Volcán Ediciones</span>

    
     <a href="https://www.instagram.com/bajoelvolcane"
      class="bev-topbar-link"
    >
      <i class="bi bi-instagram"></i>
      <i>@bajoelvolcane</i>
    </a>

  </div>
</div>

<style>
  .bev-topbar {
    background-color: var(--topbar-bg);
    border-bottom: 1px solid var(--topbar-border);
    padding: 0.95rem 0.5rem; /* Topbar más grande (aumentamos padding) */
  }

  .bev-topbar-info {
    color: var(--topbar-muted);
    font-size: 0.99rem; /* Un poco más grande que antes */
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s; /* Hover suave también en los nuevos enlaces */
  }

  .bev-topbar-info:hover {
    color: var(--topbar-hover);
  }

  .bev-topbar-marca {
    color: var(--topbar-text);
    font-size: 0.95rem; /* Un poco más grande */
    letter-spacing: 0.5em;
    text-transform: uppercase;
  }

  .bev-topbar-link {
    color: var(--topbar-muted);
    font-size: 0.95rem; /* Un poco más grande */
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }

  .bev-topbar-link:hover {
    color: var(--topbar-hover);
  }

  @media (max-width: 768px) {
    .bev-topbar-info {
      display: none;
    }
  }
</style>